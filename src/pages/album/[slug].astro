---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { createAlbumArtwork } from "../../lib/artistArtwork";
import { albums, getArtist, type Album } from "../../lib/catalog";

export function getStaticPaths() {
  return albums.map((album) => ({
    params: { slug: album.slug },
    props: { album }
  }));
}

const { album } = Astro.props as { album: Album };
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const artist = getArtist(album.artistSlug);
const imageSrc = createAlbumArtwork(album.title, album.artistName, album.slug);
const albumSchema = {
  "@context": "https://schema.org",
  "@type": "MusicAlbum",
  name: album.title,
  url: new URL(`${baseUrl}album/${album.slug}/`, Astro.site).toString(),
  image: imageSrc,
  byArtist: {
    "@type": "MusicGroup",
    name: album.artistName,
    url: new URL(`${baseUrl}artist/${album.artistSlug}/`, Astro.site).toString()
  },
  datePublished: album.year ? `${album.year}` : undefined,
  track: album.trackListing.map((song) => ({
    "@type": "MusicRecording",
    name: song.title,
    url: new URL(`${baseUrl}song/${song.slug}/`, Astro.site).toString()
  }))
};
---

<BaseLayout
  title={`${album.title} | Artist Money`}
  description={`${album.title} album page with linked songs, artist details, and tracked song revenue on Artist Money.`}
  image={imageSrc}
  imageAlt={`${album.title} by ${album.artistName}`}
  type="article"
  jsonLd={albumSchema}
>
  <article class="artist-profile">
    <div class="artist-hero">
      <img
        class="artist-profile-image album-cover-image"
        src={imageSrc}
        alt={`Cover artwork for ${album.title} by ${album.artistName}`}
        width="1200"
        height="1200"
      />
      <div class="artist-hero-copy">
        <p class="eyebrow">Album</p>
        <h1>{album.title}</h1>
        <p>
          {artist ? <a href={`${baseUrl}artist/${artist.slug}/`}>{artist.name}</a> : album.artistName}
        </p>
        <ul class="stat-list">
          {album.year && <li><strong>Released:</strong> {album.year}</li>}
          <li><strong>Tracked songs:</strong> {album.trackedSongCount}</li>
          {album.estimatedRevenue && <li><strong>Tracked revenue:</strong> {album.estimatedRevenue}</li>}
        </ul>
      </div>
    </div>

    <section aria-labelledby="album-overview-title">
      <h2 id="album-overview-title">Overview</h2>
      <p>
        This album page groups the songs currently tracked from <strong>{album.title}</strong>,
        shows the release year, and presents a usable tracklisting from the songs already in the catalog.
      </p>
    </section>

    <section aria-labelledby="album-tracklisting-title">
      <h2 id="album-tracklisting-title">Tracklisting</h2>
      <p class="results-note">This tracklisting reflects the songs currently tracked on Artist Money for this album.</p>
      <ul class="meta-list">
        {album.trackListing.map((song, index) => (
          <li>
            <strong>{index + 1}.</strong>{" "}
            <a href={`${baseUrl}song/${song.slug}/`}>{song.title}</a>
            <span class="meta-inline"> · {song.estimated_revenue}</span>
          </li>
        ))}
      </ul>
    </section>

    <section aria-labelledby="album-links-title">
      <h2 id="album-links-title">Related Links</h2>
      <ul class="meta-list">
        <li>
          Artist page: <a href={`${baseUrl}artist/${album.artistSlug}/`}>{album.artistName}</a>
        </li>
        <li>
          Browse all albums: <a href={`${baseUrl}albums/`}>Albums</a>
        </li>
      </ul>
    </section>
  </article>
</BaseLayout>
