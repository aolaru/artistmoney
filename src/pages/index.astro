---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createArtistArtwork, getArtistPhoto } from "../lib/artistArtwork";

type Artist = {
  name: string;
  slug: string;
  estimated_income: string;
  top_songs: string[];
};

type Song = {
  title: string;
  slug: string;
  artist: string;
  estimated_revenue: string;
};

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const artistModules = import.meta.glob("../data/artists/*.json", { eager: true });
const songModules = import.meta.glob("../data/songs/*.json", { eager: true });

const artists = Object.values(artistModules)
  .map((module) => module.default as Artist)
  .sort((left, right) => left.name.localeCompare(right.name));

const songs = Object.values(songModules)
  .map((module) => module.default as Song)
  .sort((left, right) => left.title.localeCompare(right.title));

const trendingSongs = songs.slice(0, 3);
const stillMakingMoneyArtists = artists.slice(0, 3);
const getArtistName = (slug: string) => artists.find((artist) => artist.slug === slug)?.name ?? slug;
---

<BaseLayout
  title="Artist Money | Understand Music Emotionally and Financially"
  description="Understand music emotionally and financially through artist pages, song pages, and simple income insights."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Artist Money</p>
      <h1>Artist Money</h1>
      <p>Understand music — emotionally and financially</p>
    </div>
    <div class="hero-panel" aria-label="Site summary">
      <strong>{songs.length}</strong>
      <span>songs tracked across the catalog</span>
    </div>
  </section>

  <section id="songs" aria-labelledby="trending-title">
    <h2 id="trending-title">Trending Songs</h2>
    <div class="card-grid">
      {trendingSongs.map((song) => (
        <article class="card artist-card">
          <img
            class="artist-card-image"
            src={
              getArtistPhoto(song.artist)?.src ??
              createArtistArtwork(getArtistName(song.artist), song.artist)
            }
            alt={getArtistPhoto(song.artist)?.alt ?? `Artwork for ${getArtistName(song.artist)}`}
            loading="lazy"
            width="1200"
            height="900"
            referrerpolicy="no-referrer"
          />
          <div class="artist-card-body">
            <p class="eyebrow">Song</p>
            <h3>
              <a href={`${baseUrl}song/${song.slug}/`}>{song.title}</a>
            </h3>
            <p class="artist-card-meta">
              By <a href={`${baseUrl}artist/${song.artist}/`}>{getArtistName(song.artist)}</a>
            </p>
            <p>Estimated revenue: {song.estimated_revenue}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="artists" aria-labelledby="artists-title">
    <h2 id="artists-title">Still Making Money</h2>
    <div class="card-grid">
      {stillMakingMoneyArtists.map((artist) => (
        <article class="card artist-card">
          <img
            class="artist-card-image"
            src={getArtistPhoto(artist.slug)?.src ?? createArtistArtwork(artist.name, artist.slug)}
            alt={getArtistPhoto(artist.slug)?.alt ?? `Artwork for ${artist.name}`}
            loading="lazy"
            width="1200"
            height="900"
            referrerpolicy="no-referrer"
          />
          <div class="artist-card-body">
            <p class="eyebrow">Artist</p>
            <h3>
              <a href={`${baseUrl}artist/${artist.slug}/`}>{artist.name}</a>
            </h3>
            <p>Estimated income: {artist.estimated_income}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section aria-labelledby="insights-title">
    <h2 id="insights-title">Insights</h2>
    <ul class="meta-list">
      <li>
        <a href={`${baseUrl}song/${trendingSongs[0]?.slug ?? ""}/`}>Why songs go viral</a>
      </li>
      <li>
        <a href={`${baseUrl}artist/${stillMakingMoneyArtists[0]?.slug ?? ""}/`}>How artists make money</a>
      </li>
    </ul>
  </section>
</BaseLayout>
