---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createArtistArtwork, getArtistPhoto } from "../lib/artistArtwork";
import { artists, getArtist, songs } from "../lib/catalog";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const featuredSongSlugs = ["blinding-lights", "gangstas-paradise", "in-this-shirt"];
const featuredArtistSlugs = ["the-weeknd", "daft-punk", "oasis"];

const featuredSongs = featuredSongSlugs
  .map((slug) => songs.find((song) => song.slug === slug))
  .filter(Boolean);

const featuredArtists = featuredArtistSlugs
  .map((slug) => artists.find((artist) => artist.slug === slug))
  .filter(Boolean);

const insightLinks = [
  {
    label: "Why songs go viral",
    href: `${baseUrl}song/in-this-shirt/`,
    detail: "A slow-burn song with viral rediscovery and long-tail streaming."
  },
  {
    label: "How artists make money",
    href: `${baseUrl}artist/daft-punk/`,
    detail: "A catalog page with artist-side share, label splits, and ownership context."
  }
];
---

<BaseLayout
  title="Artist Money | Understand Music Emotionally and Financially"
  description="Understand music emotionally and financially through artist pages, song pages, and simple income insights."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Artist Money</p>
      <h1>Artist Money</h1>
      <p>Understand music — emotionally and financially</p>
      <p>
        Artist Money breaks down what songs and catalogs may generate, what artists likely keep,
        and why certain recordings keep earning years after release.
      </p>
    </div>
    <div class="hero-panel" aria-label="Site summary">
      <strong>{songs.length}</strong>
      <span>songs tracked across the catalog</span>
    </div>
  </section>

  <section id="songs" aria-labelledby="trending-title">
    <h2 id="trending-title">Trending Songs</h2>
    <p class="results-note">Featured songs with strong replay value, cultural memory, or unusual catalog strength.</p>
    <div class="card-grid">
      {featuredSongs.map((song) => {
        const artist = getArtist(song.artist);
        const artistName = artist?.name ?? song.artist;

        return (
        <article class="card artist-card">
          <img
            class="artist-card-image"
            src={
              getArtistPhoto(song.artist)?.src ??
              createArtistArtwork(artistName, song.artist)
            }
            alt={getArtistPhoto(song.artist)?.alt ?? `Artwork for ${artistName}`}
            loading="lazy"
            width="1200"
            height="900"
            referrerpolicy="no-referrer"
          />
          <div class="artist-card-body">
            <p class="eyebrow">Song</p>
            <h3>
              <a href={`${baseUrl}song/${song.slug}/`}>{song.title}</a>
            </h3>
            <p class="artist-card-meta">
              By <a href={`${baseUrl}artist/${song.artist}/`}>{artistName}</a>
            </p>
            {(song.album || song.year) && (
              <p class="artist-card-meta">{[song.album, song.year].filter(Boolean).join(" · ")}</p>
            )}
            <p>Estimated revenue: {song.estimated_revenue}</p>
          </div>
        </article>
        );
      })}
    </div>
  </section>

  <section id="artists" aria-labelledby="artists-title">
    <h2 id="artists-title">Still Making Money</h2>
    <p class="results-note">Featured artists with durable catalogs, recurring streaming income, or unusually strong long-tail economics.</p>
    <div class="card-grid">
      {featuredArtists.map((artist) => (
        <article class="card artist-card">
          <img
            class="artist-card-image"
            src={getArtistPhoto(artist.slug)?.src ?? createArtistArtwork(artist.name, artist.slug)}
            alt={getArtistPhoto(artist.slug)?.alt ?? `Artwork for ${artist.name}`}
            loading="lazy"
            width="1200"
            height="900"
            referrerpolicy="no-referrer"
          />
          <div class="artist-card-body">
            <p class="eyebrow">Artist</p>
            <h3>
              <a href={`${baseUrl}artist/${artist.slug}/`}>{artist.name}</a>
            </h3>
            {(artist.genre || artist.country) && (
              <p class="artist-card-meta">{[artist.genre, artist.country].filter(Boolean).join(" · ")}</p>
            )}
            <p>Estimated income: {artist.estimated_income}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section aria-labelledby="insights-title">
    <h2 id="insights-title">Insights</h2>
    <ul class="meta-list">
      {insightLinks.map((link) => (
        <li>
          <a href={link.href}>{link.label}</a>
          <span class="meta-inline"> {" "}· {link.detail}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
