---
import BaseLayout from "../layouts/BaseLayout.astro";
import { songArticles } from "../data/songArticles";
import {
  getArtist,
  getArtistVisual,
  getSongConfidence,
  getSongMethodology,
  rankedSongs,
  songs
} from "../lib/catalog";
import { isSongReviewReady } from "../lib/reviewReady";
import { formatRevenueMidpoint } from "../lib/revenue";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const reviewedSongEntries = rankedSongs
  .filter(({ song }) => isSongReviewReady(song))
  .slice(0, 6);
const leadSongEntry = reviewedSongEntries[0];
const leadSong = leadSongEntry?.song;
const leadSongMethodology = leadSong ? getSongMethodology(leadSong) : undefined;
---

<BaseLayout
  title="How Much Music | Song Earnings and Catalog Value"
  description="Search song earnings estimates, explore reviewed music catalog pages, and understand how How Much Music models annual song value."
>
  <section class="hero home-hero">
    <div class="hero-copy">
      <p class="eyebrow">How Much Music</p>
      <h1>Find out what songs may earn each year.</h1>
      <p>
        How Much Music explains song earnings, catalog value, and ownership context with modeled
        annual ranges. Start with a song, then read how the estimate was built.
      </p>
    </div>

    <div class="hero-panel home-search-panel" aria-label="Primary homepage actions">
      <p class="eyebrow">Start Here</p>
      <h2>Choose one path</h2>
      <div class="home-primary-actions">
        <article class="home-primary-action">
          <p class="eyebrow">1. Search</p>
          <h3>Search a song</h3>
          <form class="home-search-form" action={`${baseUrl}search/`} method="get">
            <label class="sr-only" for="home-song-search">Search songs</label>
            <input
              id="home-song-search"
              name="q"
              type="search"
              placeholder="Try “Bohemian Rhapsody”"
              autocomplete="off"
              spellcheck="false"
            />
            <button type="submit">Search</button>
          </form>
          <p class="results-note">{songs.length} songs tracked.</p>
        </article>
        <article class="home-primary-action">
          <p class="eyebrow">2. Reviewed</p>
          <h3>See top reviewed songs</h3>
          <p>Start with article-backed song pages instead of the full generated catalog.</p>
          <a class="home-action-link" href={`${baseUrl}reviewed-songs/`}>See reviewed songs</a>
        </article>
        <article class="home-primary-action">
          <p class="eyebrow">3. Methodology</p>
          <h3>Understand the estimates</h3>
          <p>Learn why every number is a modeled range, not a public royalty statement.</p>
          <a class="home-action-link" href={`${baseUrl}insights/methodology/`}>Read methodology</a>
        </article>
      </div>
    </div>
  </section>

  {reviewedSongEntries.length > 0 && (
    <section id="top-reviewed-songs" aria-labelledby="top-reviewed-title">
      <div class="section-heading-row">
        <div>
          <p class="eyebrow">Reviewed Songs</p>
          <h2 id="top-reviewed-title">Top reviewed song pages</h2>
        </div>
        <a class="home-action-link" href={`${baseUrl}reviewed-songs/`}>Open reviewed songs</a>
      </div>
      <p class="results-note">
        These pages have article entries and visible methodology notes. They are a better starting
        point than the full generated catalog.
      </p>
      <div class="card-grid reviewed-song-grid">
        {reviewedSongEntries.map(({ song, revenueScore }) => {
          const artist = getArtist(song.artist);
          const artistName = artist?.name ?? song.artist;
          const artistVisual = artist ? getArtistVisual(artist) : undefined;
          const confidence = getSongConfidence(song);

          return (
            <article class="card artist-card reviewed-song-card">
              <img
                class="artist-card-image"
                src={artistVisual?.src ?? ""}
                alt={artistVisual?.alt ?? `Artwork for ${artistName}`}
                loading="lazy"
                width="1200"
                height="900"
                referrerpolicy="no-referrer"
              />
              <div class="artist-card-body">
                <p class="eyebrow">Song</p>
                <p class={`confidence-badge confidence-${confidence.level}`}>{confidence.level} confidence</p>
                <h3><a href={`${baseUrl}song/${song.slug}/`}>{song.title}</a></h3>
                <p class="artist-card-meta">
                  By <a href={`${baseUrl}artist/${song.artist}/`}>{artistName}</a>
                </p>
                <p class="artist-card-meta">
                  Modeled midpoint: {formatRevenueMidpoint(revenueScore)}
                </p>
              </div>
            </article>
          );
        })}
      </div>
    </section>
  )}

  <section aria-labelledby="methodology-title" class="home-methodology-section">
    <div class="methodology-card home-methodology-card">
      <p class="methodology-badge">How to read the numbers</p>
      <h2 id="methodology-title">Modeled ranges, not royalty statements</h2>
      <p>
        {leadSongMethodology?.summary ??
          "The site models annual song behavior using available ownership, split, and replay context."}
      </p>
      <ul class="meta-list">
        <li>Every estimate is a directional annual range.</li>
        <li>Song pages separate artist-side and gross revenue only where structured context exists.</li>
        <li>Corrections and source updates are handled through the contact page.</li>
      </ul>
      <p>
        <a href={`${baseUrl}insights/methodology/`}>Read the full methodology</a>
        {" "}or{" "}
        <a href={`${baseUrl}editorial-policy/`}>review the editorial policy</a>.
      </p>
    </div>
  </section>
</BaseLayout>
