---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createArtistArtwork } from "../lib/artistArtwork";

type Artist = {
  name: string;
  slug: string;
  estimated_income: string;
  top_songs: string[];
};

const artistModules = import.meta.glob("../data/artists/*.json", { eager: true });
const artists = Object.values(artistModules)
  .map((module) => module.default as Artist)
  .sort((left, right) => left.name.localeCompare(right.name));
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Artist Money | Artist Income Estimates"
  description="Browse artist profiles and simple estimated income snapshots on Artist Money."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Artist Money</p>
      <h1>Music catalog pages with a sharper visual identity and revenue snapshots.</h1>
      <p>
        Browse artist profiles, jump into song-level estimates, and explore a growing static library
        generated from JSON.
      </p>
    </div>
    <div class="hero-panel" aria-label="Site summary">
      <strong>{artists.length}</strong>
      <span>artists live in the catalog</span>
    </div>
  </section>

  <section aria-labelledby="artist-list-title">
    <h2 id="artist-list-title">Featured artists</h2>
    <div class="card-grid">
      {artists.map((artist) => (
        <article class="card artist-card">
          <img
            class="artist-card-image"
            src={createArtistArtwork(artist.name, artist.slug)}
            alt={`Artwork for ${artist.name}`}
            loading="lazy"
            width="1200"
            height="900"
          />
          <div class="artist-card-body">
            <p class="eyebrow">{artist.slug.replaceAll("-", " ")}</p>
            <h3>
              <a href={`${baseUrl}artist/${artist.slug}/`}>{artist.name}</a>
            </h3>
            <p>Estimated income: {artist.estimated_income}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
