---
import BaseLayout from "../layouts/BaseLayout.astro";
import { artists, getArtistConfidence, getArtistVisual, getConfidenceSummary, songs, type Artist } from "../lib/catalog";
import { getLatestGitDate } from "../lib/freshness";
import { isArtistReviewReady } from "../lib/reviewReady";
import { getCatalogUpdates } from "../lib/updates";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const hasPublicArtistPage = (artist: Artist) => {
  const topSongs = songs.filter((song) => artist.top_songs.includes(song.slug));
  return isArtistReviewReady(artist, topSongs) && getArtistVisual(artist).provider === "artistPhoto";
};
const reviewedArtistCount = artists.filter(hasPublicArtistPage).length;
const genres = [...new Set(artists.map((artist) => artist.genre).filter(Boolean))].sort();
const countries = [...new Set(artists.map((artist) => artist.country).filter(Boolean))].sort();
const recentUpdates = getCatalogUpdates(20);

function firstUpdateDateBySlug(slugLists: string[][]) {
  const dates = new Map<string, string>();

  slugLists.forEach((slugs, index) => {
    const date = recentUpdates[index]?.date;
    if (!date) return;
    slugs.forEach((slug) => {
      if (!dates.has(slug)) dates.set(slug, date);
    });
  });

  return dates;
}

const newArtistDates = firstUpdateDateBySlug(recentUpdates.map((entry) => entry.addedArtistSlugs));
const updatedArtistDates = firstUpdateDateBySlug(
  recentUpdates.map((entry) => entry.artistSlugs.filter((slug) => !entry.addedArtistSlugs.includes(slug)))
);
const artistBySlug = new Map(artists.map((artist) => [artist.slug, artist]));
const songBySlug = new Map(songs.map((song) => [song.slug, song]));
const latestNewArtists = [...new Set(recentUpdates.flatMap((entry) => entry.addedArtistSlugs))]
  .map((slug) => artistBySlug.get(slug))
  .filter(Boolean)
  .slice(0, 6);
const latestUpdatedArtists = [...new Set(recentUpdates.flatMap((entry) =>
  [
    ...entry.artistSlugs.filter((slug) => !entry.addedArtistSlugs.includes(slug)),
    ...entry.songSlugs
      .map((slug) => songBySlug.get(slug)?.artist)
      .filter(Boolean)
  ]
))]
  .map((slug) => artistBySlug.get(slug))
  .filter(Boolean)
  .slice(0, 6);
---

<BaseLayout
  title="Artists | How Much Music"
  description="Browse artist earnings pages, with reviewed entries highlighted for stronger notes and clearer estimate limits."
  noindex
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Artists</p>
      <h1>Artist catalog</h1>
      <p>Browse artist earnings pages. Reviewed entries have stronger notes, ownership context, and public images; the full catalog remains available for discovery.</p>
      <p><a href={`${baseUrl}reviewed-artists/`}>Open reviewed artists only</a> or <a href={`${baseUrl}insights/methodology/`}>read the methodology</a>.</p>
    </div>
    <div class="hero-panel" aria-label="Artist count">
      <strong>{artists.length}</strong>
      <span>artist pages</span>
      <span>{reviewedArtistCount} reviewed</span>
    </div>
  </section>

  <section class="catalog-path-grid" aria-label="Artist browsing options">
    <a class="catalog-path-card" href={`${baseUrl}reviewed-artists/`}>
      <span class="eyebrow">Best Start</span>
      <strong>Reviewed artists</strong>
      <span>Use these first when source depth matters.</span>
    </a>
    <a class="catalog-path-card" href={`${baseUrl}search/?type=artist`}>
      <span class="eyebrow">Find One</span>
      <strong>Search artists</strong>
      <span>Jump directly to a name or related song.</span>
    </a>
    <a class="catalog-path-card" href="#all-artists-title">
      <span class="eyebrow">Browse</span>
      <strong>Full artist list</strong>
      <span>Filter by genre, country, confidence, or image status.</span>
    </a>
  </section>

  {(latestNewArtists.length > 0 || latestUpdatedArtists.length > 0) && (
    <details class="directory-updates directory-updates-collapsed">
      <summary>
        <p class="eyebrow">Recent Updates</p>
        <h2 id="artist-updates-title">Recently changed artists</h2>
        <span>Open recent additions and updated pages.</span>
      </summary>
      {latestNewArtists.length > 0 && (
        <div class="directory-update-group">
          <h3>New artists</h3>
          <div class="update-links">
            {latestNewArtists.map((artist) => (
              <a href={`${baseUrl}artist/${artist.slug}/`}>{artist.name}</a>
            ))}
          </div>
        </div>
      )}
      {latestUpdatedArtists.length > 0 && (
        <div class="directory-update-group">
          <h3>Recently updated</h3>
          <div class="update-links">
            {latestUpdatedArtists.map((artist) => (
              <a href={`${baseUrl}artist/${artist.slug}/`}>{artist.name}</a>
            ))}
          </div>
        </div>
      )}
    </details>
  )}

  <section aria-labelledby="all-artists-title">
    <h2 id="all-artists-title">Artist Directory</h2>
    <p class="results-note">Use the search field for a quick lookup, or open filters when you want to narrow the full catalog.</p>
    <details class="advanced-filters">
      <summary>Search, filter, and sort artists</summary>
      <div class="filters" data-filter-root="artists">
        <label class="filter-field">
          <span>Search</span>
          <input id="artist-search" type="search" placeholder="Search artists" />
        </label>
        <label class="filter-field">
          <span>Status</span>
          <select id="artist-status">
            <option value="">All artist pages</option>
            <option value="reviewed">Reviewed only</option>
            <option value="catalog">Catalog entries</option>
          </select>
        </label>
        <label class="filter-field">
          <span>Genre</span>
          <select id="artist-genre">
            <option value="">All genres</option>
            {genres.map((genre) => (
              <option value={genre}>{genre}</option>
            ))}
          </select>
        </label>
        <label class="filter-field">
          <span>Country</span>
          <select id="artist-country">
            <option value="">All countries</option>
            {countries.map((country) => (
              <option value={country}>{country}</option>
            ))}
          </select>
        </label>
        <label class="filter-field">
          <span>Confidence</span>
          <select id="artist-confidence">
            <option value="">All confidence levels</option>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
          </select>
        </label>
        <label class="filter-field">
          <span>Sort</span>
          <select id="artist-sort">
            <option value="earnings">Highest earnings</option>
            <option value="alpha">Alphabetical</option>
            <option value="confidence">Highest confidence</option>
            <option value="updated">Last updated</option>
          </select>
        </label>
        <label class="filter-field">
          <span>Split detail</span>
          <select id="artist-split">
            <option value="">All pages</option>
            <option value="yes">Artist and label shares shown</option>
          </select>
        </label>
        <label class="filter-field">
          <span>Image</span>
          <select id="artist-image">
            <option value="">All image states</option>
            <option value="yes">Public photo only</option>
          </select>
        </label>
      </div>
    </details>
    <div class="active-filters" id="artist-active-filters"></div>
    <p class="results-note" id="artist-results-note">Showing {artists.length} artists</p>
    <div class="card-grid" id="artist-card-grid">
      {artists.map((artist) => (
        (() => {
          const artistVisual = getArtistVisual(artist);
          const confidence = getArtistConfidence(artist);
          const isReviewed = hasPublicArtistPage(artist);
          const revenueMidpoint = artist.normalizedRevenue?.artistSide?.midpoint ?? 0;
          const hasSplitAware = artist.earnings?.artist_or_estate_share && artist.earnings?.label_share ? "yes" : "no";
          const hasRealImage = artistVisual.provider === "artistPhoto" ? "yes" : "no";
          const updated = getLatestGitDate([
            `src/data/artists/${artist.slug}.json`,
            "src/data/artistMetadata.ts",
            "src/data/artistArticles.ts"
          ]) ?? "";
          const newDate = newArtistDates.get(artist.slug);
          const updatedDate = updatedArtistDates.get(artist.slug);
          return (
        <article
          class="card artist-card"
          data-artist-card
          data-search={`${artist.name} ${artist.genre ?? ""} ${artist.country ?? ""}`.toLowerCase()}
          data-genre={artist.genre ?? ""}
          data-country={artist.country ?? ""}
          data-confidence={confidence.level}
          data-confidence-score={confidence.score}
          data-revenue={revenueMidpoint}
          data-name={artist.name.toLowerCase()}
          data-review-status={isReviewed ? "reviewed" : "catalog"}
          data-split-aware={hasSplitAware}
          data-has-real-image={hasRealImage}
          data-updated={updated.replaceAll("-", "")}
        >
          <img
            class="artist-card-image"
            src={artistVisual.src}
            alt={artistVisual.alt}
            loading="lazy"
            width="1200"
            height="900"
            referrerpolicy="no-referrer"
          />
          <div class="artist-card-body">
              <p class="eyebrow">Artist</p>
              <p class={`confidence-badge confidence-${confidence.level}`}>{confidence.level} confidence</p>
              <p class="confidence-note">{getConfidenceSummary(confidence)} <a href={`${baseUrl}insights/methodology/`}>Why?</a></p>
              <h3>
              <a href={`${baseUrl}artist/${artist.slug}/`}>{artist.name}</a>
            </h3>
            {(artist.genre || artist.country) && (
              <p class="artist-card-meta">{[artist.genre, artist.country].filter(Boolean).join(" · ")}</p>
            )}
            <div class="quality-chip-row">
              {newDate ? (
                <span class="status-chip status-chip-new">NEW {newDate}</span>
              ) : updatedDate ? (
                <span class="status-chip status-chip-updated">UPDATED {updatedDate}</span>
              ) : null}
              {hasSplitAware === "yes" && <span class="quality-chip">split-aware</span>}
              {hasRealImage === "yes" && <span class="quality-chip">real photo</span>}
              <span class={`quality-chip ${isReviewed ? "" : "quality-chip-muted"}`}>{isReviewed ? "reviewed" : "catalog profile"}</span>
              {updated && !newDate && !updatedDate && <span class="quality-chip">updated {updated}</span>}
            </div>
            <p>Estimated income: {artist.estimated_income}</p>
          </div>
        </article>
          );
        })()
      ))}
    </div>
    <div class="directory-actions">
      <button class="load-more-button" type="button" id="artist-load-more">Show more artists</button>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const initArtistFilters = () => {
    const artistSearchInput = document.querySelector("#artist-search");
    const artistStatusSelect = document.querySelector("#artist-status");
    const artistGenreSelect = document.querySelector("#artist-genre");
    const artistCountrySelect = document.querySelector("#artist-country");
    const artistConfidenceSelect = document.querySelector("#artist-confidence");
    const artistSortSelect = document.querySelector("#artist-sort");
    const artistSplitSelect = document.querySelector("#artist-split");
    const artistImageSelect = document.querySelector("#artist-image");
    const artistCards = [...document.querySelectorAll("[data-artist-card]")];
    const artistNote = document.querySelector("#artist-results-note");
    const artistGrid = document.querySelector("#artist-card-grid");
    const activeFilters = document.querySelector("#artist-active-filters");
    const loadMoreButton = document.querySelector("#artist-load-more");
    const pageSize = 48;
    let visibleLimit = pageSize;

    if (!artistSearchInput || !artistStatusSelect || !artistGenreSelect || !artistCountrySelect || !artistConfidenceSelect || !artistSortSelect || !artistSplitSelect || !artistImageSelect || !artistNote || !artistGrid || !activeFilters || !loadMoreButton) return;
    if (artistSearchInput.dataset.filtersBound === "true") return;

    const syncUrl = () => {
      const url = new URL(window.location.href);
      const params = url.searchParams;
      const values = {
        q: artistSearchInput.value.trim(),
        status: artistStatusSelect.value,
        genre: artistGenreSelect.value,
        country: artistCountrySelect.value,
        confidence: artistConfidenceSelect.value,
        sort: artistSortSelect.value,
        split: artistSplitSelect.value,
        image: artistImageSelect.value
      };

      Object.entries(values).forEach(([key, value]) => {
        if (value) {
          params.set(key, value);
        } else {
          params.delete(key);
        }
      });

      history.replaceState({}, "", `${url.pathname}${params.toString() ? `?${params.toString()}` : ""}`);
    };

    const renderActiveFilters = () => {
      const items = [];
      if (artistSearchInput.value.trim()) items.push(`Search: ${artistSearchInput.value.trim()}`);
      if (artistStatusSelect.value) items.push(`Status: ${artistStatusSelect.selectedOptions[0]?.textContent ?? artistStatusSelect.value}`);
      if (artistGenreSelect.value) items.push(`Genre: ${artistGenreSelect.value}`);
      if (artistCountrySelect.value) items.push(`Country: ${artistCountrySelect.value}`);
      if (artistConfidenceSelect.value) items.push(`Confidence: ${artistConfidenceSelect.value}`);
      if (artistSplitSelect.value) items.push("Split-aware only");
      if (artistImageSelect.value) items.push("Real photo only");
      if (artistSortSelect.value && artistSortSelect.value !== "earnings") items.push(`Sort: ${artistSortSelect.selectedOptions[0]?.textContent ?? artistSortSelect.value}`);

      activeFilters.innerHTML = items.length
        ? `${items.map((item) => `<span class="active-filter-chip">${item}</span>`).join("")}<button type="button" class="filter-reset" id="artist-reset">Clear filters</button>`
        : "";

      const resetButton = document.querySelector("#artist-reset");
      resetButton?.addEventListener("click", () => {
        artistSearchInput.value = "";
        artistStatusSelect.value = "";
        artistGenreSelect.value = "";
        artistCountrySelect.value = "";
        artistConfidenceSelect.value = "";
        artistSplitSelect.value = "";
        artistImageSelect.value = "";
        artistSortSelect.value = "earnings";
        visibleLimit = pageSize;
        applyArtistFilters();
      }, { once: true });
    };

    const applyArtistFilters = () => {
      const query = artistSearchInput.value.trim().toLowerCase();
      const status = artistStatusSelect.value;
      const genre = artistGenreSelect.value;
      const country = artistCountrySelect.value;
      const confidence = artistConfidenceSelect.value;
      const split = artistSplitSelect.value;
      const image = artistImageSelect.value;
      const sort = artistSortSelect.value;

      let matched = 0;

      artistCards.forEach((card) => {
        const matchesQuery = !query || card.dataset.search?.includes(query);
        const matchesStatus = !status || card.dataset.reviewStatus === status;
        const matchesGenre = !genre || card.dataset.genre === genre;
        const matchesCountry = !country || card.dataset.country === country;
        const matchesConfidence = !confidence || card.dataset.confidence === confidence;
        const matchesSplit = !split || card.dataset.splitAware === split;
        const matchesImage = !image || card.dataset.hasRealImage === image;
        const show = Boolean(matchesQuery && matchesStatus && matchesGenre && matchesCountry && matchesConfidence && matchesSplit && matchesImage);

        if (show) matched += 1;
        card.dataset.matchesFilter = show ? "yes" : "no";
      });

      const sortedCards = [...artistCards].sort((left, right) => {
        if (sort === "alpha") {
          return (left.dataset.name ?? "").localeCompare(right.dataset.name ?? "");
        }

        if (sort === "confidence") {
          return Number(right.dataset.confidenceScore ?? 0) - Number(left.dataset.confidenceScore ?? 0)
            || Number(right.dataset.revenue ?? 0) - Number(left.dataset.revenue ?? 0);
        }

        if (sort === "updated") {
          return Number(right.dataset.updated ?? 0) - Number(left.dataset.updated ?? 0)
            || Number(right.dataset.revenue ?? 0) - Number(left.dataset.revenue ?? 0);
        }

        return Number(right.dataset.revenue ?? 0) - Number(left.dataset.revenue ?? 0)
          || (left.dataset.name ?? "").localeCompare(right.dataset.name ?? "");
      });

      sortedCards.forEach((card) => artistGrid.appendChild(card));

      let shown = 0;
      sortedCards.forEach((card) => {
        const matches = card.dataset.matchesFilter === "yes";
        const withinLimit = matches && shown < visibleLimit;
        card.classList.toggle("is-hidden", !withinLimit);
        if (matches && withinLimit) shown += 1;
      });

      artistNote.textContent = matched > shown
        ? `Showing ${shown} of ${matched} artists`
        : `Showing ${matched} artist${matched === 1 ? "" : "s"}`;
      loadMoreButton.hidden = shown >= matched;
      renderActiveFilters();
      syncUrl();
    };

    const resetLimitAndApply = () => {
      visibleLimit = pageSize;
      applyArtistFilters();
    };

    const params = new URLSearchParams(window.location.search);
    artistSearchInput.value = params.get("q") ?? "";
    artistStatusSelect.value = params.get("status") ?? "";
    artistGenreSelect.value = params.get("genre") ?? "";
    artistCountrySelect.value = params.get("country") ?? "";
    artistConfidenceSelect.value = params.get("confidence") ?? "";
    artistSplitSelect.value = params.get("split") ?? "";
    artistImageSelect.value = params.get("image") ?? "";
    artistSortSelect.value = params.get("sort") ?? "earnings";

    [artistSearchInput, artistStatusSelect, artistGenreSelect, artistCountrySelect, artistConfidenceSelect, artistSortSelect, artistSplitSelect, artistImageSelect].forEach((element) => {
      element.addEventListener("input", resetLimitAndApply);
      element.addEventListener("change", resetLimitAndApply);
    });

    loadMoreButton.addEventListener("click", () => {
      visibleLimit += pageSize;
      applyArtistFilters();
    });

    artistSearchInput.dataset.filtersBound = "true";
    applyArtistFilters();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initArtistFilters, { once: true });
  } else {
    initArtistFilters();
  }

  document.addEventListener("astro:page-load", initArtistFilters);
</script>
