---
import BaseLayout from "../layouts/BaseLayout.astro";
import { artists, getArtistConfidence, getArtistVisual, getConfidenceSummary } from "../lib/catalog";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const genres = [...new Set(artists.map((artist) => artist.genre).filter(Boolean))].sort();
const countries = [...new Set(artists.map((artist) => artist.country).filter(Boolean))].sort();
---

<BaseLayout
  title="Artists | How Much Music"
  description="Browse all artists tracked on How Much Music."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Artists</p>
      <h1>All artists in the catalog</h1>
      <p>Browse the full artist index and jump into income-focused artist pages.</p>
      <p><a href={`${baseUrl}insights/methodology/`}>Confidence badges link back to the site methodology.</a></p>
    </div>
    <div class="hero-panel" aria-label="Artist count">
      <strong>{artists.length}</strong>
      <span>artists in How Much Music</span>
    </div>
  </section>

  <section aria-labelledby="all-artists-title">
    <h2 id="all-artists-title">Artist Directory</h2>
    <div class="filters" data-filter-root="artists">
      <label class="filter-field">
        <span>Search</span>
        <input id="artist-search" type="search" placeholder="Search artists" />
      </label>
      <label class="filter-field">
        <span>Genre</span>
        <select id="artist-genre">
          <option value="">All genres</option>
          {genres.map((genre) => (
            <option value={genre}>{genre}</option>
          ))}
        </select>
      </label>
      <label class="filter-field">
        <span>Country</span>
        <select id="artist-country">
          <option value="">All countries</option>
          {countries.map((country) => (
            <option value={country}>{country}</option>
          ))}
        </select>
      </label>
      <label class="filter-field">
        <span>Confidence</span>
        <select id="artist-confidence">
          <option value="">All confidence levels</option>
          <option value="high">High</option>
          <option value="medium">Medium</option>
          <option value="low">Low</option>
        </select>
      </label>
      <label class="filter-field">
        <span>Sort</span>
        <select id="artist-sort">
          <option value="earnings">Highest earnings</option>
          <option value="alpha">Alphabetical</option>
          <option value="confidence">Highest confidence</option>
        </select>
      </label>
    </div>
    <div class="active-filters" id="artist-active-filters"></div>
    <p class="results-note" id="artist-results-note">Showing {artists.length} artists</p>
    <div class="card-grid" id="artist-card-grid">
      {artists.map((artist) => (
        (() => {
          const artistVisual = getArtistVisual(artist);
          const confidence = getArtistConfidence(artist);
          const revenueMidpoint = artist.normalizedRevenue?.artistSide?.midpoint ?? 0;
          return (
        <article
          class="card artist-card"
          data-artist-card
          data-search={`${artist.name} ${artist.genre ?? ""} ${artist.country ?? ""}`.toLowerCase()}
          data-genre={artist.genre ?? ""}
          data-country={artist.country ?? ""}
          data-confidence={confidence.level}
          data-confidence-score={confidence.score}
          data-revenue={revenueMidpoint}
          data-name={artist.name.toLowerCase()}
        >
          <img
            class="artist-card-image"
            src={artistVisual.src}
            alt={artistVisual.alt}
            loading="lazy"
            width="1200"
            height="900"
            referrerpolicy="no-referrer"
          />
          <div class="artist-card-body">
              <p class="eyebrow">Artist</p>
              <p class={`confidence-badge confidence-${confidence.level}`}>{confidence.level} confidence</p>
              <p class="confidence-note">{getConfidenceSummary(confidence)} <a href={`${baseUrl}insights/methodology/`}>Why?</a></p>
              <h3>
              <a href={`${baseUrl}artist/${artist.slug}/`}>{artist.name}</a>
            </h3>
            {(artist.genre || artist.country) && (
              <p class="artist-card-meta">{[artist.genre, artist.country].filter(Boolean).join(" · ")}</p>
            )}
            <p>Estimated income: {artist.estimated_income}</p>
          </div>
        </article>
          );
        })()
      ))}
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const initArtistFilters = () => {
    const artistSearchInput = document.querySelector("#artist-search");
    const artistGenreSelect = document.querySelector("#artist-genre");
    const artistCountrySelect = document.querySelector("#artist-country");
    const artistConfidenceSelect = document.querySelector("#artist-confidence");
    const artistSortSelect = document.querySelector("#artist-sort");
    const artistCards = [...document.querySelectorAll("[data-artist-card]")];
    const artistNote = document.querySelector("#artist-results-note");
    const artistGrid = document.querySelector("#artist-card-grid");
    const activeFilters = document.querySelector("#artist-active-filters");

    if (!artistSearchInput || !artistGenreSelect || !artistCountrySelect || !artistConfidenceSelect || !artistSortSelect || !artistNote || !artistGrid || !activeFilters) return;
    if (artistSearchInput.dataset.filtersBound === "true") return;

    const syncUrl = () => {
      const url = new URL(window.location.href);
      const params = url.searchParams;
      const values = {
        q: artistSearchInput.value.trim(),
        genre: artistGenreSelect.value,
        country: artistCountrySelect.value,
        confidence: artistConfidenceSelect.value,
        sort: artistSortSelect.value
      };

      Object.entries(values).forEach(([key, value]) => {
        if (value) {
          params.set(key, value);
        } else {
          params.delete(key);
        }
      });

      history.replaceState({}, "", `${url.pathname}${params.toString() ? `?${params.toString()}` : ""}`);
    };

    const renderActiveFilters = () => {
      const items = [];
      if (artistSearchInput.value.trim()) items.push(`Search: ${artistSearchInput.value.trim()}`);
      if (artistGenreSelect.value) items.push(`Genre: ${artistGenreSelect.value}`);
      if (artistCountrySelect.value) items.push(`Country: ${artistCountrySelect.value}`);
      if (artistConfidenceSelect.value) items.push(`Confidence: ${artistConfidenceSelect.value}`);
      if (artistSortSelect.value && artistSortSelect.value !== "earnings") items.push(`Sort: ${artistSortSelect.selectedOptions[0]?.textContent ?? artistSortSelect.value}`);

      activeFilters.innerHTML = items.length
        ? `${items.map((item) => `<span class="active-filter-chip">${item}</span>`).join("")}<button type="button" class="filter-reset" id="artist-reset">Clear filters</button>`
        : "";

      const resetButton = document.querySelector("#artist-reset");
      resetButton?.addEventListener("click", () => {
        artistSearchInput.value = "";
        artistGenreSelect.value = "";
        artistCountrySelect.value = "";
        artistConfidenceSelect.value = "";
        artistSortSelect.value = "earnings";
        applyArtistFilters();
      }, { once: true });
    };

    const applyArtistFilters = () => {
      const query = artistSearchInput.value.trim().toLowerCase();
      const genre = artistGenreSelect.value;
      const country = artistCountrySelect.value;
      const confidence = artistConfidenceSelect.value;
      const sort = artistSortSelect.value;

      let visible = 0;

      artistCards.forEach((card) => {
        const matchesQuery = !query || card.dataset.search?.includes(query);
        const matchesGenre = !genre || card.dataset.genre === genre;
        const matchesCountry = !country || card.dataset.country === country;
        const matchesConfidence = !confidence || card.dataset.confidence === confidence;
        const show = Boolean(matchesQuery && matchesGenre && matchesCountry && matchesConfidence);

        card.classList.toggle("is-hidden", !show);
        if (show) visible += 1;
      });

      const sortedCards = [...artistCards].sort((left, right) => {
        if (sort === "alpha") {
          return (left.dataset.name ?? "").localeCompare(right.dataset.name ?? "");
        }

        if (sort === "confidence") {
          return Number(right.dataset.confidenceScore ?? 0) - Number(left.dataset.confidenceScore ?? 0)
            || Number(right.dataset.revenue ?? 0) - Number(left.dataset.revenue ?? 0);
        }

        return Number(right.dataset.revenue ?? 0) - Number(left.dataset.revenue ?? 0)
          || (left.dataset.name ?? "").localeCompare(right.dataset.name ?? "");
      });

      sortedCards.forEach((card) => artistGrid.appendChild(card));

      artistNote.textContent = `Showing ${visible} artist${visible === 1 ? "" : "s"}`;
      renderActiveFilters();
      syncUrl();
    };

    const params = new URLSearchParams(window.location.search);
    artistSearchInput.value = params.get("q") ?? "";
    artistGenreSelect.value = params.get("genre") ?? "";
    artistCountrySelect.value = params.get("country") ?? "";
    artistConfidenceSelect.value = params.get("confidence") ?? "";
    artistSortSelect.value = params.get("sort") ?? "earnings";

    [artistSearchInput, artistGenreSelect, artistCountrySelect, artistConfidenceSelect, artistSortSelect].forEach((element) => {
      element.addEventListener("input", applyArtistFilters);
      element.addEventListener("change", applyArtistFilters);
    });

    artistSearchInput.dataset.filtersBound = "true";
    applyArtistFilters();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initArtistFilters, { once: true });
  } else {
    initArtistFilters();
  }

  document.addEventListener("astro:page-load", initArtistFilters);
</script>
