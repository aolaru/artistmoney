---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import {
  getArtistConfidence,
  getArtistVisual,
  getConfidenceSummary,
  rankedArtists,
  songs
} from "../lib/catalog";
import { getArtistReviewReferences, isArtistReviewReady } from "../lib/reviewReady";
import { formatRevenueMidpoint } from "../lib/revenue";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const reviewedArtists = rankedArtists
  .map((entry) => {
    const topSongs = songs.filter((song) => entry.artist.top_songs.includes(song.slug));
    const visual = getArtistVisual(entry.artist);
    const references = getArtistReviewReferences(entry.artist, topSongs);

    return {
      ...entry,
      topSongs,
      visual,
      references,
      isReviewReady: isArtistReviewReady(entry.artist, topSongs) && visual.provider === "artistPhoto"
    };
  })
  .filter((entry) => entry.isReviewReady);
---

<BaseLayout
  title="Reviewed Artists | How Much Music"
  description="Reviewed artist earnings pages with source context, ownership notes, and methodology-backed annual estimates."
>
  <Breadcrumbs items={[
    { label: "Home", href: baseUrl },
    { label: "Reviewed Artists" }
  ]} />

  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Reviewed Artists</p>
      <h1>Start with the strongest artist pages.</h1>
      <p>
        These artist pages have page-specific editorial notes, structured earnings fields, visible
        references, ownership context, and self-hosted artist images.
      </p>
      <p>
        Looking for songs instead? <a href={`${baseUrl}reviewed-songs/`}>Open reviewed songs</a>.
      </p>
    </div>
    <div class="hero-panel" aria-label="Reviewed artist count">
      <strong>{reviewedArtists.length}</strong>
      <span>review-ready artist pages</span>
    </div>
  </section>

  <section class="editorial-basis-card" aria-labelledby="reviewed-artists-guide-title">
    <div class="editorial-basis-heading">
      <p class="eyebrow">Reader Guide</p>
      <h2 id="reviewed-artists-guide-title">What makes these pages stronger</h2>
      <p>
        Each linked page has page-specific editorial notes, structured earnings fields, public
        references, ownership context, and a self-hosted artist image.
      </p>
    </div>
    <div class="editorial-basis-grid">
      <div class="editorial-basis-item">
        <strong>Estimate type</strong>
        <span>Artist-side ranges are modeled annual estimates, not private statements from artists, estates, labels, or publishers.</span>
      </div>
      <div class="editorial-basis-item">
        <strong>Source role</strong>
        <span>References support public catalog context, top-song identity, or certification lookup context where records exist.</span>
      </div>
      <div class="editorial-basis-item">
        <strong>Confidence role</strong>
        <span>Confidence labels describe how complete the public context is, not guaranteed payout accuracy.</span>
      </div>
    </div>
  </section>

  <section aria-labelledby="reviewed-artist-list-title">
    <div class="section-heading-row">
      <div>
        <p class="eyebrow">Article-backed</p>
        <h2 id="reviewed-artist-list-title">Reviewed artist pages</h2>
      </div>
      <a class="home-action-link" href={`${baseUrl}insights/catalog-ownership/`}>Understand ownership</a>
    </div>
    <p class="results-note">
      Ranked by modeled artist-side annual midpoint, with priority given to pages that have stronger
      source and ownership context.
    </p>

    <div class="card-grid reviewed-song-grid">
      {reviewedArtists.map(({ artist, revenueScore, visual, references }) => {
        const confidence = getArtistConfidence(artist);

        return (
          <article class="card artist-card reviewed-song-card">
            <img
              class="artist-card-image"
              src={visual.src}
              alt={visual.alt}
              loading="lazy"
              width="1200"
              height="900"
              referrerpolicy="no-referrer"
            />
            <div class="artist-card-body">
              <p class="eyebrow">Reviewed Artist</p>
              <p class={`confidence-badge confidence-${confidence.level}`}>{confidence.level} confidence</p>
              <p class="confidence-note">{getConfidenceSummary(confidence)} <a href={`${baseUrl}insights/methodology/`}>Why?</a></p>
              <h3><a href={`${baseUrl}artist/${artist.slug}/`}>{artist.name}</a></h3>
              <p class="artist-card-meta">
                {[artist.genre, artist.country].filter(Boolean).join(" · ")}
              </p>
              <p class="artist-card-meta">
                Modeled midpoint: {formatRevenueMidpoint(revenueScore)}
              </p>
              <p class="artist-card-meta">
                {references.length} public reference{references.length === 1 ? "" : "s"} linked.
              </p>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
