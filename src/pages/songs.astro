---
import BaseLayout from "../layouts/BaseLayout.astro";
import { artists, getArtist, getArtistVisual, getConfidenceSummary, getSongConfidence, songs, type Artist } from "../lib/catalog";
import { getLatestGitDate } from "../lib/freshness";
import { isArtistReviewReady, isSongReviewReady } from "../lib/reviewReady";
import { getCatalogUpdates } from "../lib/updates";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const hasPublicArtistPage = (artist: Artist) => {
  const topSongs = songs.filter((song) => artist.top_songs.includes(song.slug));
  return isArtistReviewReady(artist, topSongs) && getArtistVisual(artist).provider === "artistPhoto";
};
const reviewedSongs = songs.filter(isSongReviewReady);
const reviewedSongCount = reviewedSongs.length;
const songArtistSlugs = new Set(songs.map((song) => song.artist));
const artistOptions = artists
  .filter((artist) => songArtistSlugs.has(artist.slug))
  .map((artist) => ({ slug: artist.slug, name: artist.name }));
const decades = [...new Set(songs.map((song) => (song.year ? `${Math.floor(song.year / 10) * 10}s` : null)).filter(Boolean))].sort();
const recentUpdates = getCatalogUpdates(20);

function firstUpdateDateBySlug(slugLists: string[][]) {
  const dates = new Map<string, string>();

  slugLists.forEach((slugs, index) => {
    const date = recentUpdates[index]?.date;
    if (!date) return;
    slugs.forEach((slug) => {
      if (!dates.has(slug)) dates.set(slug, date);
    });
  });

  return dates;
}

const newSongDates = firstUpdateDateBySlug(recentUpdates.map((entry) => entry.addedSongSlugs));
const updatedSongDates = firstUpdateDateBySlug(
  recentUpdates.map((entry) => entry.songSlugs.filter((slug) => !entry.addedSongSlugs.includes(slug)))
);
const songBySlug = new Map(songs.map((song) => [song.slug, song]));
const latestNewSongs = [...new Set(recentUpdates.flatMap((entry) => entry.addedSongSlugs))]
  .map((slug) => songBySlug.get(slug))
  .filter(Boolean)
  .slice(0, 6);
const latestUpdatedSongs = [...new Set(recentUpdates.flatMap((entry) =>
  entry.songSlugs.filter((slug) => !entry.addedSongSlugs.includes(slug))
))]
  .map((slug) => songBySlug.get(slug))
  .filter(Boolean)
  .slice(0, 6);
---

<BaseLayout
  title="Songs | How Much Music"
  description="Browse song earnings pages, with reviewed entries highlighted for stronger notes and clearer estimate limits."
  noindex
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Songs</p>
      <h1>Song catalog</h1>
      <p>Browse song earnings pages. Reviewed entries include page-specific context, visible references, and methodology notes; the full catalog remains available for discovery.</p>
      <p><a href={`${baseUrl}reviewed-songs/`}>Open reviewed songs only</a> or <a href={`${baseUrl}insights/methodology/`}>read the methodology</a>.</p>
    </div>
    <div class="hero-panel" aria-label="Song catalog summary">
      <p class="eyebrow">Catalog Snapshot</p>
      <a class="hero-stat-pill hero-stat-pill-primary" href="#all-songs-title">
        <strong>{songs.length}</strong>
        <span>song pages</span>
      </a>
      <a class="hero-stat-pill" href={`${baseUrl}reviewed-songs/`}>
        <strong>{reviewedSongCount}</strong>
        <span>reviewed songs</span>
      </a>
    </div>
  </section>

  <section class="catalog-path-grid" aria-label="Song browsing options">
    <a class="catalog-path-card" href={`${baseUrl}reviewed-songs/`}>
      <span class="eyebrow">Best Start</span>
      <strong>Reviewed songs</strong>
      <span>Use these first when source depth matters.</span>
    </a>
    <a class="catalog-path-card" href={`${baseUrl}search/?type=song`}>
      <span class="eyebrow">Find One</span>
      <strong>Search songs</strong>
      <span>Jump directly to a title, artist, or album.</span>
    </a>
    <a class="catalog-path-card" href="#all-songs-title">
      <span class="eyebrow">Browse</span>
      <strong>Full song list</strong>
      <span>Filter by artist, decade, confidence, or image status.</span>
    </a>
  </section>

  {(latestNewSongs.length > 0 || latestUpdatedSongs.length > 0) && (
    <details class="directory-updates directory-updates-collapsed">
      <summary>
        <p class="eyebrow">Recent Updates</p>
        <h2 id="song-updates-title">Recently changed songs</h2>
        <span>Open recent additions and updated pages.</span>
      </summary>
      {latestNewSongs.length > 0 && (
        <div class="directory-update-group">
          <h3>New songs</h3>
          <div class="update-links">
            {latestNewSongs.map((song) => {
              const artist = getArtist(song.artist);
              return (
                <a href={`${baseUrl}song/${song.slug}/`}>
                  {song.title} <span>{artist?.name ?? song.artist}</span>
                </a>
              );
            })}
          </div>
        </div>
      )}
      {latestUpdatedSongs.length > 0 && (
        <div class="directory-update-group">
          <h3>Recently updated</h3>
          <div class="update-links">
            {latestUpdatedSongs.map((song) => {
              const artist = getArtist(song.artist);
              return (
                <a href={`${baseUrl}song/${song.slug}/`}>
                  {song.title} <span>{artist?.name ?? song.artist}</span>
                </a>
              );
            })}
          </div>
        </div>
      )}
    </details>
  )}

  <section aria-labelledby="all-songs-title">
    <h2 id="all-songs-title">Song Directory</h2>
    <p class="results-note">Use the search field for a quick lookup, or open filters when you want to narrow the full catalog.</p>
    <details class="advanced-filters">
      <summary>Search, filter, and sort songs</summary>
      <div class="filters" data-filter-root="songs">
        <label class="filter-field">
          <span>Search</span>
          <input id="song-search" type="search" placeholder="Search songs or albums" />
        </label>
        <label class="filter-field">
          <span>Status</span>
          <select id="song-status">
            <option value="">All song pages</option>
            <option value="reviewed">Reviewed only</option>
            <option value="catalog">Catalog entries</option>
          </select>
        </label>
        <label class="filter-field">
          <span>Artist</span>
          <select id="song-artist">
            <option value="">All artists</option>
            {artistOptions.map((artist) => (
              <option value={artist.slug}>{artist.name}</option>
            ))}
          </select>
        </label>
        <label class="filter-field">
          <span>Decade</span>
          <select id="song-decade">
            <option value="">All decades</option>
            {decades.map((decade) => (
              <option value={decade}>{decade}</option>
            ))}
          </select>
        </label>
        <label class="filter-field">
          <span>Confidence</span>
          <select id="song-confidence">
            <option value="">All confidence levels</option>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
          </select>
        </label>
        <label class="filter-field">
          <span>Sort</span>
          <select id="song-sort">
            <option value="earnings">Highest earnings</option>
            <option value="alpha">Alphabetical</option>
            <option value="year">Newest release year</option>
            <option value="confidence">Highest confidence</option>
            <option value="updated">Last updated</option>
          </select>
        </label>
        <label class="filter-field">
          <span>Split detail</span>
          <select id="song-split">
            <option value="">All pages</option>
            <option value="yes">Artist-side and gross ranges shown</option>
          </select>
        </label>
        <label class="filter-field">
          <span>Image</span>
          <select id="song-image">
            <option value="">All image states</option>
            <option value="yes">Sourced image only</option>
          </select>
        </label>
      </div>
    </details>
    <div class="active-filters" id="song-active-filters"></div>
    <p class="results-note" id="song-results-note">Showing {songs.length} songs</p>
    <div class="card-grid" id="song-card-grid">
      {songs.map((song) => {
        const artist = getArtist(song.artist);
        const artistName = artist?.name ?? song.artist;
        const artistVisual = artist ? getArtistVisual(artist) : undefined;
        const artistIsPublic = artist ? hasPublicArtistPage(artist) : false;
        const isReviewed = isSongReviewReady(song);
        const decade = song.year ? `${Math.floor(song.year / 10) * 10}s` : "";
        const confidence = getSongConfidence(song);
        const revenueMidpoint = song.normalizedRevenue?.artistSide?.midpoint ?? 0;
        const hasSplitAware = song.earnings?.artist_or_estate_share && song.earnings?.gross_track_revenue ? "yes" : "no";
        const hasSourcedImage = artistVisual && artistVisual.provider !== "generated" ? "yes" : "no";
        const updated = getLatestGitDate([
          `src/data/songs/${song.slug}.json`,
          "src/data/songMetadata.ts",
          "src/data/songArticles.ts"
        ]) ?? "";
        const newDate = newSongDates.get(song.slug);
        const updatedDate = updatedSongDates.get(song.slug);

        return (
          <article
            class="card artist-card"
            data-song-card
            data-search={`${song.title} ${artistName} ${song.album ?? ""}`.toLowerCase()}
            data-artist={song.artist}
            data-decade={decade}
            data-confidence={confidence.level}
            data-confidence-score={confidence.score}
            data-revenue={revenueMidpoint}
            data-year={song.year ?? 0}
            data-name={song.title.toLowerCase()}
            data-review-status={isReviewed ? "reviewed" : "catalog"}
            data-split-aware={hasSplitAware}
            data-has-image={hasSourcedImage}
            data-updated={updated.replaceAll("-", "")}
          >
            <img
              class="artist-card-image"
              src={artistVisual?.src ?? ""}
              alt={artistVisual?.alt ?? `Artwork for ${artistName}`}
              loading="lazy"
              width="1200"
              height="900"
              referrerpolicy="no-referrer"
            />
            <div class="artist-card-body">
              <p class="eyebrow">Song</p>
              <p class={`confidence-badge confidence-${confidence.level}`}>{confidence.level} confidence</p>
              <p class="confidence-note">{getConfidenceSummary(confidence)} <a href={`${baseUrl}insights/methodology/`}>Why?</a></p>
              <h3>
                <a href={`${baseUrl}song/${song.slug}/`}>{song.title}</a>
              </h3>
              <p class="artist-card-meta">
                By {artist && artistIsPublic ? <a href={`${baseUrl}artist/${song.artist}/`}>{artistName}</a> : artistName}
              </p>
              {(song.album || song.year) && (
                <p class="artist-card-meta">
                  {song.album}
                  {song.album && song.year && " · "}
                  {song.year}
                </p>
              )}
              <div class="quality-chip-row">
                {newDate ? (
                  <span class="status-chip status-chip-new">NEW {newDate}</span>
                ) : updatedDate ? (
                  <span class="status-chip status-chip-updated">UPDATED {updatedDate}</span>
                ) : null}
                {hasSplitAware === "yes" && <span class="quality-chip">split-aware</span>}
                {hasSourcedImage === "yes" && <span class="quality-chip">sourced image</span>}
                <span class={`quality-chip ${isReviewed ? "" : "quality-chip-muted"}`}>{isReviewed ? "reviewed" : "catalog profile"}</span>
                {updated && !newDate && !updatedDate && <span class="quality-chip">updated {updated}</span>}
              </div>
              <p>Estimated revenue: {song.estimated_revenue}</p>
            </div>
          </article>
        );
      })}
    </div>
    <div class="directory-actions">
      <button class="load-more-button" type="button" id="song-load-more">Show more songs</button>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const initSongFilters = () => {
    const songSearchInput = document.querySelector("#song-search");
    const songStatusSelect = document.querySelector("#song-status");
    const songArtistSelect = document.querySelector("#song-artist");
    const songDecadeSelect = document.querySelector("#song-decade");
    const songConfidenceSelect = document.querySelector("#song-confidence");
    const songSortSelect = document.querySelector("#song-sort");
    const songSplitSelect = document.querySelector("#song-split");
    const songImageSelect = document.querySelector("#song-image");
    const songCards = [...document.querySelectorAll("[data-song-card]")];
    const songNote = document.querySelector("#song-results-note");
    const songGrid = document.querySelector("#song-card-grid");
    const activeFilters = document.querySelector("#song-active-filters");
    const loadMoreButton = document.querySelector("#song-load-more");
    const pageSize = 48;
    let visibleLimit = pageSize;

    if (!songSearchInput || !songStatusSelect || !songArtistSelect || !songDecadeSelect || !songConfidenceSelect || !songSortSelect || !songSplitSelect || !songImageSelect || !songNote || !songGrid || !activeFilters || !loadMoreButton) return;
    if (songSearchInput.dataset.filtersBound === "true") return;

    const syncUrl = () => {
      const url = new URL(window.location.href);
      const values = {
        q: songSearchInput.value.trim(),
        status: songStatusSelect.value,
        artist: songArtistSelect.value,
        decade: songDecadeSelect.value,
        confidence: songConfidenceSelect.value,
        sort: songSortSelect.value,
        split: songSplitSelect.value,
        image: songImageSelect.value
      };

      Object.entries(values).forEach(([key, value]) => {
        if (value) {
          url.searchParams.set(key, value);
        } else {
          url.searchParams.delete(key);
        }
      });

      history.replaceState({}, "", `${url.pathname}${url.searchParams.toString() ? `?${url.searchParams.toString()}` : ""}`);
    };

    const renderActiveFilters = () => {
      const items = [];
      if (songSearchInput.value.trim()) items.push(`Search: ${songSearchInput.value.trim()}`);
      if (songStatusSelect.value) items.push(`Status: ${songStatusSelect.selectedOptions[0]?.textContent ?? songStatusSelect.value}`);
      if (songArtistSelect.value) items.push(`Artist: ${songArtistSelect.selectedOptions[0]?.textContent ?? songArtistSelect.value}`);
      if (songDecadeSelect.value) items.push(`Decade: ${songDecadeSelect.value}`);
      if (songConfidenceSelect.value) items.push(`Confidence: ${songConfidenceSelect.value}`);
      if (songSplitSelect.value) items.push("Split-aware only");
      if (songImageSelect.value) items.push("Sourced image only");
      if (songSortSelect.value && songSortSelect.value !== "earnings") items.push(`Sort: ${songSortSelect.selectedOptions[0]?.textContent ?? songSortSelect.value}`);

      activeFilters.innerHTML = items.length
        ? `${items.map((item) => `<span class="active-filter-chip">${item}</span>`).join("")}<button type="button" class="filter-reset" id="song-reset">Clear filters</button>`
        : "";

      const resetButton = document.querySelector("#song-reset");
      resetButton?.addEventListener("click", () => {
        songSearchInput.value = "";
        songStatusSelect.value = "";
        songArtistSelect.value = "";
        songDecadeSelect.value = "";
        songConfidenceSelect.value = "";
        songSplitSelect.value = "";
        songImageSelect.value = "";
        songSortSelect.value = "earnings";
        visibleLimit = pageSize;
        applySongFilters();
      }, { once: true });
    };

    const applySongFilters = () => {
      const query = songSearchInput.value.trim().toLowerCase();
      const status = songStatusSelect.value;
      const artist = songArtistSelect.value;
      const decade = songDecadeSelect.value;
      const confidence = songConfidenceSelect.value;
      const split = songSplitSelect.value;
      const image = songImageSelect.value;
      const sort = songSortSelect.value;

      let matched = 0;

      songCards.forEach((card) => {
        const matchesQuery = !query || card.dataset.search?.includes(query);
        const matchesStatus = !status || card.dataset.reviewStatus === status;
        const matchesArtist = !artist || card.dataset.artist === artist;
        const matchesDecade = !decade || card.dataset.decade === decade;
        const matchesConfidence = !confidence || card.dataset.confidence === confidence;
        const matchesSplit = !split || card.dataset.splitAware === split;
        const matchesImage = !image || card.dataset.hasImage === image;
        const show = Boolean(matchesQuery && matchesStatus && matchesArtist && matchesDecade && matchesConfidence && matchesSplit && matchesImage);

        if (show) matched += 1;
        card.dataset.matchesFilter = show ? "yes" : "no";
      });

      const sortedCards = [...songCards].sort((left, right) => {
        if (sort === "alpha") {
          return (left.dataset.name ?? "").localeCompare(right.dataset.name ?? "");
        }

        if (sort === "year") {
          return Number(right.dataset.year ?? 0) - Number(left.dataset.year ?? 0)
            || Number(right.dataset.revenue ?? 0) - Number(left.dataset.revenue ?? 0);
        }

        if (sort === "confidence") {
          return Number(right.dataset.confidenceScore ?? 0) - Number(left.dataset.confidenceScore ?? 0)
            || Number(right.dataset.revenue ?? 0) - Number(left.dataset.revenue ?? 0);
        }

        if (sort === "updated") {
          return Number(right.dataset.updated ?? 0) - Number(left.dataset.updated ?? 0)
            || Number(right.dataset.revenue ?? 0) - Number(left.dataset.revenue ?? 0);
        }

        return Number(right.dataset.revenue ?? 0) - Number(left.dataset.revenue ?? 0)
          || (left.dataset.name ?? "").localeCompare(right.dataset.name ?? "");
      });

      sortedCards.forEach((card) => songGrid.appendChild(card));

      let shown = 0;
      sortedCards.forEach((card) => {
        const matches = card.dataset.matchesFilter === "yes";
        const withinLimit = matches && shown < visibleLimit;
        card.classList.toggle("is-hidden", !withinLimit);
        if (matches && withinLimit) shown += 1;
      });

      songNote.textContent = matched > shown
        ? `Showing ${shown} of ${matched} songs`
        : `Showing ${matched} song${matched === 1 ? "" : "s"}`;
      loadMoreButton.hidden = shown >= matched;
      renderActiveFilters();
      syncUrl();
    };

    const resetLimitAndApply = () => {
      visibleLimit = pageSize;
      applySongFilters();
    };

    const params = new URLSearchParams(window.location.search);
    songSearchInput.value = params.get("q") ?? "";
    songStatusSelect.value = params.get("status") ?? "";
    songArtistSelect.value = params.get("artist") ?? "";
    songDecadeSelect.value = params.get("decade") ?? "";
    songConfidenceSelect.value = params.get("confidence") ?? "";
    songSplitSelect.value = params.get("split") ?? "";
    songImageSelect.value = params.get("image") ?? "";
    songSortSelect.value = params.get("sort") ?? "earnings";

    [songSearchInput, songStatusSelect, songArtistSelect, songDecadeSelect, songConfidenceSelect, songSortSelect, songSplitSelect, songImageSelect].forEach((element) => {
      element.addEventListener("input", resetLimitAndApply);
      element.addEventListener("change", resetLimitAndApply);
    });

    loadMoreButton.addEventListener("click", () => {
      visibleLimit += pageSize;
      applySongFilters();
    });

    songSearchInput.dataset.filtersBound = "true";
    applySongFilters();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initSongFilters, { once: true });
  } else {
    initSongFilters();
  }

  document.addEventListener("astro:page-load", initSongFilters);
</script>
