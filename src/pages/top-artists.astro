---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { getArtistConfidence, getArtistVisual, getConfidenceSummary, rankedArtists, songs, type Artist } from "../lib/catalog";
import { isArtistReviewReady } from "../lib/reviewReady";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const hasPublicArtistPage = (artist: Artist) => {
  const topSongs = songs.filter((song) => artist.top_songs.includes(song.slug));
  return isArtistReviewReady(artist, topSongs) && getArtistVisual(artist).provider === "artistPhoto";
};
const entries = rankedArtists.filter((entry) => entry.revenueRange && hasPublicArtistPage(entry.artist)).slice(0, 25);
---

<BaseLayout
  title="Top Earning Artists | How Much Music"
  description="Compare reviewed artist pages by modeled annual artist-side earnings, with rankings based on estimated range midpoints."
  noindex
>
  <Breadcrumbs items={[
    { label: "Home", href: baseUrl },
    { label: "Top Artists" }
  ]} />

  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Rankings</p>
      <h1>Top earning artists in the catalog</h1>
      <p>
        These rankings use the midpoint of each artist's modeled annual earnings range. They are
        editorial estimates, not public royalty statements.
      </p>
      <p><a href={`${baseUrl}insights/methodology/`}>Read the ranking methodology</a></p>
    </div>
    <div class="hero-panel" aria-label="Ranked artist count">
      <strong>{entries.length}</strong>
      <span>artists with structured revenue ranges</span>
    </div>
  </section>

  <section aria-labelledby="top-artists-title">
    <h2 id="top-artists-title">Artist Ranking</h2>
    <div class="card-grid">
      {entries.map(({ artist, revenueRange }, index) => {
        const artistVisual = getArtistVisual(artist);
        const confidence = getArtistConfidence(artist);
        return (
        <article class="card artist-card ranked-card">
          <img
            class="artist-card-image"
            src={artistVisual.src}
            alt={artistVisual.alt}
            loading="lazy"
            width="1200"
            height="900"
            referrerpolicy="no-referrer"
          />
          <div class="artist-card-body">
            <p class="rank-badge">#{index + 1}</p>
              <p class="eyebrow">Artist</p>
              <p class={`confidence-badge confidence-${confidence.level}`}>{confidence.level} confidence</p>
              <p class="confidence-note">{getConfidenceSummary(confidence)} <a href={`${baseUrl}insights/methodology/`}>Why?</a></p>
              <h3><a href={`${baseUrl}artist/${artist.slug}/`}>{artist.name}</a></h3>
            {(artist.genre || artist.country) && (
              <p class="artist-card-meta">{[artist.genre, artist.country].filter(Boolean).join(" · ")}</p>
            )}
            <p>Estimated artist-side annual earnings: {artist.estimated_income}</p>
            {revenueRange && (
              <p class="artist-card-meta">
                Modeled midpoint: {Math.round((revenueRange.min + revenueRange.max) / 2).toLocaleString("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 })}
              </p>
            )}
          </div>
        </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
