---
import BaseLayout from "../layouts/BaseLayout.astro";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const searchIndexUrl = `${baseUrl}search-index.json`;
---

<BaseLayout
  title="Search | How Much Music"
  description="Search music earnings pages, including reviewed pages and noindex catalog profiles."
  noindex
>
  <section class="search-page-hero">
    <p class="eyebrow">Search</p>
    <h1>Search artists and songs</h1>
    <p>
      Search reviewed pages and noindex catalog profiles. Reviewed pages have stronger source
      context; catalog profiles remain available for navigation and comparison.
    </p>
  </section>

  <section class="search-page-shell" data-search-page>
    <form class="search-page-form" action={`${baseUrl}search/`} method="get">
      <label class="sr-only" for="catalog-search-page">Search artists and songs</label>
      <input
        id="catalog-search-page"
        class="search-page-input"
        name="q"
        type="search"
        placeholder="Search artists or songs"
        autocomplete="off"
        spellcheck="false"
      />
      <button type="submit" class="search-page-submit">Search</button>
    </form>

    <div class="search-page-controls">
      <div class="search-filter-chips" role="tablist" aria-label="Search result type">
        <button type="button" class="search-filter-chip is-active" data-search-filter="all">All</button>
        <button type="button" class="search-filter-chip" data-search-filter="artist">Artists</button>
        <button type="button" class="search-filter-chip" data-search-filter="song">Songs</button>
      </div>
      <p class="results-note" data-search-status>Start typing or submit a query to search catalog pages.</p>
    </div>

    <div class="search-results-shell" data-search-results></div>
  </section>

  <script is:inline define:vars={{ searchIndexUrl, baseUrl }}>
    (() => {
      let searchItemsPromise;

      const normalize = (value) => value.toLowerCase().trim();
      const escapeHtml = (value) =>
        value
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");

      const escapeRegex = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

      const highlight = (value, query) => {
        if (!query) return escapeHtml(value);
        const regex = new RegExp(`(${escapeRegex(query)})`, "ig");
        return escapeHtml(value).replace(regex, "<mark>$1</mark>");
      };

      const scoreItem = (item, query) => {
        const title = item.titleLower;
        const subtitle = item.subtitleLower ?? "";
        const searchText = item.searchText;

        let score = 0;
        if (title === query) score += 300;
        if (title.startsWith(query)) score += 180;
        if (title.includes(query)) score += 120;
        if (subtitle.startsWith(query)) score += 70;
        if (subtitle.includes(query)) score += 40;
        if (searchText.includes(query)) score += 20;
        return score;
      };

      const fetchSearchItems = async () => {
        if (!searchItemsPromise) {
          searchItemsPromise = fetch(searchIndexUrl)
            .then((response) => {
              if (!response.ok) {
                throw new Error(`Search index request failed: ${response.status}`);
              }
              return response.json();
            })
            .then((items) =>
              items.map((item) => ({
                ...item,
                typeKey: item.type.toLowerCase(),
                titleLower: item.title.toLowerCase(),
                subtitleLower: (item.subtitle ?? "").toLowerCase(),
                searchText: item.searchText.toLowerCase()
              }))
            );
        }

        return searchItemsPromise;
      };

      const renderResults = async () => {
        const root = document.querySelector("[data-search-page]");
        if (!root) return;

        const form = root.querySelector(".search-page-form");
        const input = root.querySelector(".search-page-input");
        const resultsRoot = root.querySelector("[data-search-results]");
        const status = root.querySelector("[data-search-status]");
        const filterButtons = [...root.querySelectorAll("[data-search-filter]")];

        if (!form || !input || !resultsRoot || !status || filterButtons.length === 0) return;

        const params = new URLSearchParams(window.location.search);
        const query = params.get("q") ?? "";
        const requestedFilter = (params.get("type") ?? "all").toLowerCase();
        const filter = ["artist", "song"].includes(requestedFilter) ? requestedFilter : "all";
        input.value = query;

        filterButtons.forEach((button) => {
          button.classList.toggle("is-active", button.dataset.searchFilter === filter);
        });

        const normalizedQuery = normalize(query);
        if (!normalizedQuery) {
          resultsRoot.innerHTML = `
            <div class="trust-card">
              <h2>Search artists or songs</h2>
              <p>Try an artist name, a song title, or a mix like “mariah christmas” or “pink floyd”. Reviewed pages are labeled separately from catalog profiles.</p>
            </div>
          `;
          status.textContent = "Start typing or submit a query to search catalog pages.";
          return;
        }

        status.textContent = "Searching…";

        try {
          const items = await fetchSearchItems();
          const scoredMatches = items
            .map((item) => ({ item, score: scoreItem(item, normalizedQuery) }))
            .filter((entry) => entry.score > 0)
            .sort((left, right) => right.score - left.score || left.item.title.localeCompare(right.item.title));

          const filteredMatches =
            filter === "all" ? scoredMatches : scoredMatches.filter(({ item }) => item.typeKey === filter);

          const grouped = {
            artist: filteredMatches.filter(({ item }) => item.typeKey === "artist"),
            song: filteredMatches.filter(({ item }) => item.typeKey === "song")
          };

          const total = filteredMatches.length;
          status.textContent = total > 0
            ? `${total} result${total === 1 ? "" : "s"} for “${query}”`
            : `No results for “${query}”`;

          if (total === 0) {
            resultsRoot.innerHTML = `
              <div class="trust-card">
                <h2>No results found</h2>
                <p>Try a shorter query, an artist name, or part of a song title.</p>
              </div>
            `;
            return;
          }

          const sections = [
            { key: "artist", label: "Artists", items: grouped.artist },
            { key: "song", label: "Songs", items: grouped.song }
          ]
            .filter((section) => section.items.length > 0)
            .map((section) => `
              <section class="search-group" aria-labelledby="search-group-${section.key}">
                <div class="search-group-header">
                  <h2 id="search-group-${section.key}">${section.label}</h2>
                  <span class="meta-inline">${section.items.length}</span>
                </div>
                <div class="search-result-list">
                  ${section.items.slice(0, 12).map(({ item }) => `
                    <article class="search-result-card">
                      <p class="eyebrow">${item.type}</p>
                      <h3>
                        <a
                          href="${item.url}"
                          data-search-result-link
                          data-result-type="${escapeHtml(item.type)}"
                          data-result-title="${escapeHtml(item.title)}"
                          data-result-url="${escapeHtml(item.url)}"
                          data-result-reviewed="${item.reviewed ? "true" : "false"}"
                        >${highlight(item.title, normalizedQuery)}</a>
                      </h3>
                      <p class="search-result-status ${item.reviewed ? "is-reviewed" : "is-draft"}">${escapeHtml(item.status ?? "")}</p>
                      ${item.subtitle ? `<p class="artist-card-meta">${highlight(item.subtitle, normalizedQuery)}</p>` : ""}
                    </article>
                  `).join("")}
                </div>
              </section>
            `)
            .join("");

          resultsRoot.innerHTML = sections;
        } catch (_error) {
          status.textContent = "Search is unavailable right now.";
          resultsRoot.innerHTML = `
            <div class="trust-card">
              <h2>Search is unavailable</h2>
              <p>The catalog index could not be loaded right now. Try refreshing the page.</p>
            </div>
          `;
        }
      };

      const updateQueryParam = (key, value) => {
        const url = new URL(window.location.href);
        if (value) {
          url.searchParams.set(key, value);
        } else {
          url.searchParams.delete(key);
        }
        history.replaceState({}, "", `${url.pathname}${url.search}`);
      };

      const initSearchPage = () => {
        const root = document.querySelector("[data-search-page]");
        if (!root || root.dataset.bound === "true") return;
        root.dataset.bound = "true";

        const form = root.querySelector(".search-page-form");
        const input = root.querySelector(".search-page-input");
        const filterButtons = [...root.querySelectorAll("[data-search-filter]")];

        if (!form || !input || filterButtons.length === 0) return;

        const trackSearchSubmit = () => {
          const searchTerm = input.value.trim();
          if (!searchTerm || typeof window.hmmTrackEvent !== "function") return;
          window.hmmTrackEvent("search_submitted", {
            search_term: searchTerm,
            search_location: "search_page"
          });
        };

        form.addEventListener("submit", (event) => {
          event.preventDefault();
          trackSearchSubmit();
          updateQueryParam("q", input.value.trim());
          renderResults();
        });

        input.addEventListener("keydown", (event) => {
          if (event.key === "Enter") {
            event.preventDefault();
            trackSearchSubmit();
            updateQueryParam("q", input.value.trim());
            renderResults();
          }
        });

        root.addEventListener("click", (event) => {
          if (!(event.target instanceof Element)) return;
          const link = event.target.closest("[data-search-result-link]");
          if (!link || typeof window.hmmTrackEvent !== "function") return;
          window.hmmTrackEvent("search_result_opened", {
            search_location: "search_page",
            result_type: link.dataset.resultType ?? "",
            result_title: link.dataset.resultTitle ?? "",
            result_url: link.dataset.resultUrl ?? "",
            result_reviewed: link.dataset.resultReviewed ?? ""
          });
        });

        filterButtons.forEach((button) => {
          button.addEventListener("click", () => {
            updateQueryParam("type", button.dataset.searchFilter === "all" ? "" : button.dataset.searchFilter);
            renderResults();
          });
        });

        renderResults();
      };

      initSearchPage();
      document.addEventListener("astro:page-load", initSearchPage);
    })();
  </script>
</BaseLayout>
