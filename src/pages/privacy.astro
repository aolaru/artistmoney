---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Privacy Policy | How Much Music"
  description="Privacy policy for How Much Music, including analytics, advertising, cookies, and contact email handling."
>
  <Breadcrumbs items={[{ label: "Home", href: baseUrl }, { label: "Privacy Policy" }]} />

  <section>
    <p class="eyebrow">Privacy</p>
    <h1>Privacy Policy</h1>
    <p>
      How Much Music is a public editorial website. This page explains the basic data practices for
      analytics, advertising, cookies, and messages sent to the site.
    </p>
  </section>

  <section>
    <h2>Analytics and Advertising</h2>
    <p>
      The site uses Google Analytics to understand aggregate traffic and page performance. The site
      also includes Google AdSense code, which may use cookies or similar technologies to serve and
      measure ads if advertising is active.
    </p>
    <p>
      Google may use data from visits to this and other websites to personalize or measure ads. You
      can review Google's advertising controls at
      <a href="https://myadcenter.google.com/" rel="noreferrer" target="_blank">My Ad Center</a>.
    </p>
  </section>

  <section>
    <h2>Contact Messages</h2>
    <p>
      If you email the site, the message may include your email address, name, and any information
      you choose to send. That information is used to respond to the request, review corrections, or
      handle rights and source questions.
    </p>
  </section>

  <section>
    <h2>External Links</h2>
    <p>
      Pages may link to music platforms, Wikimedia Commons, Google services, or other external
      sources. Those sites have their own privacy policies and are not controlled by How Much Music.
    </p>
  </section>

  <section>
    <h2>Contact</h2>
    <p>
      Privacy questions can be sent to
      <a href="mailto:contact@howmuchmusic.com">contact@howmuchmusic.com</a>.
    </p>
  </section>
</BaseLayout>
