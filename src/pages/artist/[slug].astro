---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { createArtistArtwork, getArtistPhoto } from "../../lib/artistArtwork";
import { artistArticles } from "../../data/artistArticles";

type Artist = {
  name: string;
  slug: string;
  estimated_income: string;
  top_songs: string[];
  earnings?: {
    gross_catalog_revenue?: string;
    artist_or_estate_share?: string;
    label_share?: string;
    publisher_share?: string;
    writer_share?: string;
    assumptions?: string;
  };
  ownership?: {
    master_owner?: string;
    publishing_owner?: string;
    catalog_sale_status?: string;
    notes?: string;
  };
  genre?: string;
  country?: string;
  active_since?: string;
  bio?: string;
  notable_for?: string;
  career_highlight?: string;
  revenue_drivers?: string[];
};

type Song = {
  title: string;
  slug: string;
  artist: string;
  estimated_revenue: string;
};

export function getStaticPaths() {
  const artistModules = import.meta.glob("../../data/artists/*.json", { eager: true });
  const artists = Object.values(artistModules).map((module) => module.default as Artist);

  return artists.map((artist) => ({
    params: { slug: artist.slug },
    props: { artist }
  }));
}

const songModules = import.meta.glob("../../data/songs/*.json", { eager: true });
const songs = Object.values(songModules).map((module) => module.default as Song);

const { artist } = Astro.props as { artist: Artist };
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const artistSongs = songs.filter((song) => artist.top_songs.includes(song.slug));
const artistPhoto = getArtistPhoto(artist.slug);
const article = artistArticles[artist.slug];
const hasDetailedEarnings = Boolean(artist.earnings || artist.ownership);
---

<BaseLayout
  title={article?.seoTitle ?? `${artist.name} | Artist Money`}
  description={article?.shortAnswer ?? `${artist.name} artist page with income estimates, songs, and revenue strategy on Artist Money.`}
>
  <article class="artist-profile">
    <div class="artist-hero">
      <img
        class="artist-profile-image"
        src={artistPhoto?.src ?? createArtistArtwork(artist.name, artist.slug)}
        alt={artistPhoto?.alt ?? `Artwork for ${artist.name}`}
        width="1200"
        height="900"
        referrerpolicy="no-referrer"
      />
      <div class="artist-hero-copy">
        <p class="eyebrow">Artist</p>
        <h1>{artist.name}</h1>
        <p>Artist pages combine meaning, catalog value, and simple money signals.</p>
        {artistPhoto && (
          <p class="image-credit">
            {artistPhoto.credit}. License:
            {" "}
            <a href={artistPhoto.licenseUrl} rel="noreferrer" target="_blank">{artistPhoto.license}</a>
            {" · "}
            <a href={artistPhoto.sourceUrl} rel="noreferrer" target="_blank">source</a>
          </p>
        )}
      </div>
    </div>

    <section aria-labelledby="overview-title">
      <h2 id="overview-title">Overview</h2>
      <p>
        {artist.bio ??
          `${artist.name} has a catalog that keeps attracting attention through streaming, replay value, and long-term listener interest.`}
      </p>
      {(artist.genre || artist.country || artist.active_since) && (
        <ul class="meta-list">
          {artist.genre && <li><strong>Genre:</strong> {artist.genre}</li>}
          {artist.country && <li><strong>Country:</strong> {artist.country}</li>}
          {artist.active_since && <li><strong>Active since:</strong> {artist.active_since}</li>}
        </ul>
      )}
    </section>

    {article && (
      <>
        <section aria-labelledby="short-answer-title">
          <h2 id="short-answer-title">Short Answer</h2>
          <p><strong>{article.shortAnswer}</strong></p>
        </section>

        <section aria-labelledby="sources-title">
          <h2 id="sources-title">Sources</h2>
          <ul class="meta-list">
            {article.sources.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </section>
      </>
    )}

    <section aria-labelledby="income-title">
      <h2 id="income-title">Estimated Artist-Side Annual Earnings</h2>
      <ul class="meta-list">
        <li>{artist.earnings?.artist_or_estate_share ?? artist.estimated_income}</li>
      </ul>
    </section>

    {hasDetailedEarnings && (
      <>
        {artist.earnings && (
          <section aria-labelledby="breakdown-title">
            <h2 id="breakdown-title">Revenue Breakdown</h2>
            <ul class="meta-list">
              {artist.earnings.gross_catalog_revenue && (
                <li><strong>Estimated gross catalog revenue:</strong> {artist.earnings.gross_catalog_revenue}</li>
              )}
              {artist.earnings.artist_or_estate_share && (
                <li><strong>Estimated artist or estate cut:</strong> {artist.earnings.artist_or_estate_share}</li>
              )}
              {artist.earnings.label_share && (
                <li><strong>Estimated label share:</strong> {artist.earnings.label_share}</li>
              )}
              {artist.earnings.publisher_share && (
                <li><strong>Estimated publisher share:</strong> {artist.earnings.publisher_share}</li>
              )}
              {artist.earnings.writer_share && (
                <li><strong>Estimated writer share:</strong> {artist.earnings.writer_share}</li>
              )}
              {artist.earnings.assumptions && (
                <li><strong>Assumptions:</strong> {artist.earnings.assumptions}</li>
              )}
            </ul>
          </section>
        )}

        {artist.ownership && (
          <section aria-labelledby="ownership-title">
            <h2 id="ownership-title">Ownership and Catalog Status</h2>
            <ul class="meta-list">
              {artist.ownership.master_owner && (
                <li><strong>Masters:</strong> {artist.ownership.master_owner}</li>
              )}
              {artist.ownership.publishing_owner && (
                <li><strong>Publishing:</strong> {artist.ownership.publishing_owner}</li>
              )}
              {artist.ownership.catalog_sale_status && (
                <li><strong>Catalog sale status:</strong> {artist.ownership.catalog_sale_status}</li>
              )}
              {artist.ownership.notes && (
                <li><strong>Notes:</strong> {artist.ownership.notes}</li>
              )}
            </ul>
          </section>
        )}
      </>
    )}

    <section aria-labelledby="songs-title">
      <h2 id="songs-title">Top Songs</h2>
      <ul class="meta-list">
        {artistSongs.map((song) => (
          <li>
            <a href={`${baseUrl}song/${song.slug}/`}>{song.title}</a>
          </li>
        ))}
      </ul>
    </section>

    <section aria-labelledby="strategy-title">
      <h2 id="strategy-title">Revenue Strategy</h2>
      <ul class="meta-list">
        {(artist.revenue_drivers ?? [
          "Catalog income keeps older songs active long after release.",
          "Streaming creates steady long-tail revenue from repeat listening.",
          "Licensing can turn a familiar song into a fresh earnings spike."
        ]).map((point) => (
          <li>{point}</li>
        ))}
      </ul>
    </section>

    {(artist.notable_for || artist.career_highlight) && (
      <section aria-labelledby="highlights-title">
        <h2 id="highlights-title">Key Career Highlights</h2>
        <ul class="meta-list">
          {artist.notable_for && <li><strong>Known for:</strong> {artist.notable_for}</li>}
          {artist.career_highlight && <li><strong>Highlight:</strong> {artist.career_highlight}</li>}
        </ul>
      </section>
    )}

    {article && (
      <section aria-labelledby="insight-title">
        <h2 id="insight-title">Insight</h2>
        <p>{article.insight}</p>
      </section>
    )}
  </article>
</BaseLayout>
