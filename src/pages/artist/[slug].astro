---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { artistArticles } from "../../data/artistArticles";
import {
  artists,
  getConfidenceSummary,
  getArtistConfidence,
  getArtistMethodology,
  getArtistOverviewText,
  getArtistOwnershipNote,
  getArtistRevenueContext,
  getArtistVisual,
  getRelatedArtists,
  rankedArtists,
  songs,
  type Artist
} from "../../lib/catalog";
import { getArtistEditorial } from "../../lib/editorial";
import { formatFreshnessDate, getLatestGitDate } from "../../lib/freshness";
import { formatRevenueMidpoint, normalizeRevenue } from "../../lib/revenue";

export function getStaticPaths() {
  return artists.map((artist) => ({
    params: { slug: artist.slug },
    props: { artist }
  }));
}

const { artist } = Astro.props as { artist: Artist };
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const artistSongs = songs.filter((song) => artist.top_songs.includes(song.slug));
const article = artistArticles[artist.slug];
const hasDetailedEarnings = Boolean(artist.earnings || artist.ownership);
const artistVisual = getArtistVisual(artist);
const imageSrc = artistVisual.src;
const editorial = getArtistEditorial(artist, artistSongs);
const methodology = getArtistMethodology(artist);
const confidence = getArtistConfidence(artist);
const ownershipNote = getArtistOwnershipNote(artist);
const relatedArtists = getRelatedArtists(artist, 4);
const overviewText = getArtistOverviewText(artist);
const revenueContext = getArtistRevenueContext(artist).slice(0, 3);
const artistRank = rankedArtists.findIndex((entry) => entry.artist.slug === artist.slug) + 1;
const artistPercentile = artistRank > 0 ? Math.max(1, Math.round((artistRank / rankedArtists.length) * 100)) : undefined;
const activeSinceYear = artist.active_since ? Number(artist.active_since.match(/\d{4}/)?.[0]) : undefined;
const yearsActive = activeSinceYear ? new Date().getFullYear() - activeSinceYear : undefined;
const leadRevenue = artist.earnings?.artist_or_estate_share ?? artist.estimated_income;
const snippetQuestion = `How much money does ${artist.name} make?`;
const snippetLead = hasDetailedEarnings
  ? `${artist.name} is modeled at ${leadRevenue} per year on the artist side, with gross catalog revenue and ownership context separated below.`
  : `${artist.name} is modeled at ${leadRevenue} per year from streaming, publishing, licensing, and long-tail catalog demand.`;
const snippetSupport = yearsActive && yearsActive >= 10
  ? `${artist.name} still reads as an earning catalog roughly ${yearsActive} years after becoming active.`
  : artistRank > 0
    ? `${artist.name} currently ranks around the top ${artistPercentile}% of tracked artists on the site by modeled artist-side earnings.`
    : `${artist.name} is modeled using the same catalog-ranking logic applied across the site.`;
const takeaway = hasDetailedEarnings
  ? `${artist.name} works as a durable earnings page because the artist-side estimate, ownership context, and gross catalog framing can all be separated cleanly.`
  : `${artist.name} keeps earning because the catalog still shows replay demand across streaming, publishing, licensing, and broader cultural memory.`;
const statItems = [
  artistRank > 0 ? `Currently ranks around the top ${artistPercentile}% of tracked artists by modeled artist-side earnings` : undefined,
  activeSinceYear ? `Active since ${activeSinceYear}${yearsActive ? ` and still commercially relevant roughly ${yearsActive} years later` : ""}` : undefined,
  artistSongs.length ? `${artistSongs.length} tracked top songs currently support this page` : undefined,
  artist.genre ? `${artist.genre} remains the clearest genre lane for this catalog` : undefined,
  `${confidence.level} confidence estimate`
].filter(Boolean);
const revenueBarCandidates = [
  artist.earnings?.gross_catalog_revenue
    ? {
        label: "Gross catalog revenue",
        value: artist.earnings.gross_catalog_revenue,
        midpoint: normalizeRevenue(artist.earnings.gross_catalog_revenue)?.midpoint ?? 0
      }
    : undefined,
  leadRevenue
    ? {
        label: "Artist-side share",
        value: leadRevenue,
        midpoint: normalizeRevenue(leadRevenue)?.midpoint ?? 0
      }
    : undefined,
  artist.earnings?.label_share
    ? {
        label: "Label share",
        value: artist.earnings.label_share,
        midpoint: normalizeRevenue(artist.earnings.label_share)?.midpoint ?? 0
      }
    : undefined,
  artist.earnings?.publisher_share
    ? {
        label: "Publisher share",
        value: artist.earnings.publisher_share,
        midpoint: normalizeRevenue(artist.earnings.publisher_share)?.midpoint ?? 0
      }
    : undefined,
  artist.earnings?.writer_share
    ? {
        label: "Writer share",
        value: artist.earnings.writer_share,
        midpoint: normalizeRevenue(artist.earnings.writer_share)?.midpoint ?? 0
      }
    : undefined
].filter(Boolean);
const revenueBarsMax = Math.max(...revenueBarCandidates.map((entry) => entry.midpoint), 0);
const revenueBars = revenueBarCandidates.map((entry) => ({
  ...entry,
  width: revenueBarsMax > 0 ? Math.max(18, Math.round((entry.midpoint / revenueBarsMax) * 100)) : 100
}));
const comparisonArtists = relatedArtists
  .map((relatedArtist) => {
    const sameCountry = artist.country && relatedArtist.country && artist.country === relatedArtist.country;
    const sameGenre = artist.genre && relatedArtist.genre && artist.genre === relatedArtist.genre;
    const sameEra = activeSinceYear && relatedArtist.active_since
      ? Math.abs(Number(relatedArtist.active_since.match(/\d{4}/)?.[0] ?? 0) - activeSinceYear) <= 10
      : false;
    const reasons = [
      sameGenre ? "same genre" : "",
      sameCountry ? "same country" : "",
      sameEra ? "same era" : ""
    ].filter(Boolean);

    return {
      artist: relatedArtist,
      reason: reasons.slice(0, 2).join(" · "),
      revenueScore: normalizeRevenue(relatedArtist.earnings?.artist_or_estate_share ?? relatedArtist.estimated_income)?.midpoint ?? 0
    };
  })
  .sort((left, right) => right.revenueScore - left.revenueScore)
  .slice(0, 3);
const intentQuestions = [
  {
    question: `How much does ${artist.name} make in a year?`,
    answer: snippetLead
  },
  {
    question: `Why does ${artist.name} still make money?`,
    answer: revenueContext.join(" ")
  },
  {
    question: `Who controls ${artist.name}'s catalog?`,
    answer: ownershipNote
  }
];
const trafficMagnetNote = artistRank > 0 && artistPercentile
  ? `${artist.name} sits in the top ${artistPercentile}% of tracked artists on the site by modeled artist-side earnings.`
  : `${artist.name} is positioned here using the same catalog-ranking model applied across the site.`;
const topArtistsByEarnings = rankedArtists
  .filter((entry) => entry.artist.slug !== artist.slug)
  .slice(0, 5);
const lastUpdated = formatFreshnessDate(
  getLatestGitDate([
    `src/data/artists/${artist.slug}.json`,
    "src/data/artistMetadata.ts",
    "src/data/artistArticles.ts",
    "src/pages/artist/[slug].astro"
  ])
);
const artistTrustItems = [
  { label: "Modeled artist-side range", value: leadRevenue },
  { label: "Gross catalog revenue", value: artist.earnings?.gross_catalog_revenue ?? "Not separated on this page" },
  { label: "Ownership context", value: artist.ownership ? "Included below" : "High-level only" },
  { label: "Last updated", value: lastUpdated ?? "Current build" }
];
const artistSchema = {
  "@context": "https://schema.org",
  "@type": "MusicGroup",
  name: artist.name,
  url: new URL(`${baseUrl}artist/${artist.slug}/`, Astro.site).toString(),
  image: imageSrc,
  genre: artist.genre,
  foundingLocation: artist.country,
  description:
    artist.bio ??
    `${artist.name} artist page with income estimates, songs, and revenue strategy on How Much Music.`,
  track: artistSongs.map((song) => ({
    "@type": "MusicRecording",
    name: song.title,
    url: new URL(`${baseUrl}song/${song.slug}/`, Astro.site).toString()
  }))
};
---

<BaseLayout
  title={article?.seoTitle ?? `${artist.name} | How Much Music`}
  description={article?.shortAnswer ?? `${artist.name} artist page with income estimates, songs, and revenue strategy on How Much Music.`}
  image={imageSrc}
  imageAlt={artistVisual.alt}
  type="article"
  jsonLd={artistSchema}
>
  <article class="artist-profile">
    <Breadcrumbs items={[
      { label: "Home", href: baseUrl },
      { label: "Artists", href: `${baseUrl}artists/` },
      { label: artist.name }
    ]} />

    <section class="song-page-shell" aria-labelledby="artist-title">
      <div class="song-primary-flow">
        <p class="eyebrow">Artist</p>
        <h1 id="artist-title">{artist.name}</h1>
        <p class="song-kicker">{[artist.genre, artist.country, artist.active_since].filter(Boolean).join(" · ")}</p>
        <p class={`confidence-badge confidence-${confidence.level}`}>{confidence.level} confidence</p>
        <section class="trust-snapshot" aria-label="Page trust snapshot">
          <p class="confidence-note">
            {getConfidenceSummary(confidence)}
            {" "}
            <a href={`${baseUrl}insights/methodology/`}>Why?</a>
          </p>
          <p class="trust-summary">{methodology.summary}</p>
          <div class="trust-points">
            {artistTrustItems.map((item) => (
              <div class="trust-point">
                <strong>{item.label}</strong>
                <span>{item.value}</span>
              </div>
            ))}
          </div>
        </section>

        <div class="artist-hero">
          <img
            class="artist-profile-image"
            src={imageSrc}
            alt={artistVisual.alt}
            width="1200"
            height="900"
            referrerpolicy="no-referrer"
          />
          <div class="artist-hero-copy">
            <p>{overviewText}</p>
            {artistVisual.provider === "appleMusic" && artistVisual.providerLink && (
              <p class="image-credit">
                Artwork shown via Apple Music.
                {" "}
                <a href={artistVisual.providerLink} rel="noreferrer" target="_blank">Open source track</a>
              </p>
            )}
            {artistVisual.provider === "artistPhoto" && artistVisual.providerLink && (
              <p class="image-credit">
                Artist image source:
                {" "}
                <a href={artistVisual.providerLink} rel="noreferrer" target="_blank">Wikimedia Commons</a>
              </p>
            )}
          </div>
        </div>

        <section aria-labelledby="short-answer-title" class="song-intro-card">
          <h2 id="short-answer-title">Short Answer</h2>
          <p class="seo-question"><strong>{snippetQuestion}</strong></p>
          <p class="song-lead-answer"><strong>{snippetLead}</strong></p>
          <p class="song-takeaway"><strong>Takeaway:</strong> {takeaway}</p>
          <p>{article?.shortAnswer ?? editorial.shortAnswer}</p>

          <div class="song-intro-grid">
            <div class="song-intro-panel">
              <h3>Did You Know?</h3>
              <ul class="song-bullet-list">
                {statItems.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>

            <div class="song-intro-panel">
              <h3>Why This Catalog Still Works</h3>
              <ul class="song-bullet-list">
                {revenueContext.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
          </div>

          <p class="traffic-magnet-note">{trafficMagnetNote}</p>
          <div class="song-intro-footer">
            <p class="results-note">{snippetSupport}</p>
            {lastUpdated && <p class="results-note">Last updated: {lastUpdated}</p>}
          </div>
        </section>

        {comparisonArtists.length > 0 && (
          <section aria-labelledby="comparison-title" class="comparison-section">
            <h2 id="comparison-title">How It Compares</h2>
            <p class="comparison-summary">
              {artist.name} is compared against nearby artists in the catalog based on genre, country, era, and modeled earnings range.
            </p>
            <div class="comparison-list">
              <div class="comparison-row comparison-head">
                <span>Artist</span>
                <span>Why compare</span>
                <span>Estimated yearly midpoint</span>
              </div>
              <div class="comparison-row comparison-current">
                <div>
                  <a href={`${baseUrl}artist/${artist.slug}/`}><strong>{artist.name}</strong></a>
                  <div class="comparison-reason">current page</div>
                </div>
                <span>{[artist.genre, artist.country].filter(Boolean).join(" · ") || "current page"}</span>
                <strong>{formatRevenueMidpoint(normalizeRevenue(leadRevenue)?.midpoint)}</strong>
              </div>
              {comparisonArtists.map(({ artist: comparisonArtist, reason, revenueScore }) => (
                <div class="comparison-row">
                  <div>
                    <a href={`${baseUrl}artist/${comparisonArtist.slug}/`}>{comparisonArtist.name}</a>
                    {reason && <div class="comparison-reason">{reason}</div>}
                  </div>
                  <span>{reason || [comparisonArtist.genre, comparisonArtist.country].filter(Boolean).join(" · ")}</span>
                  <span>{formatRevenueMidpoint(revenueScore)}</span>
                </div>
              ))}
            </div>
          </section>
        )}

        {revenueBars.length > 1 && (
          <section aria-labelledby="revenue-visual-title">
            <h2 id="revenue-visual-title">Revenue Breakdown</h2>
            <div class="revenue-bars">
              {revenueBars.map((entry) => (
                <div class="revenue-bar-row">
                  <div class="revenue-bar-copy">
                    <strong>{entry.label}</strong>
                    <span>{entry.value}</span>
                  </div>
                  <div class="revenue-bar-track" aria-hidden="true">
                    <div class="revenue-bar-fill" style={`width: ${entry.width}%`}></div>
                  </div>
                  <div class="revenue-bar-scale">{entry.width}% of the lead revenue lane</div>
                </div>
              ))}
            </div>
            <p class="results-note">Bars reflect modeled annual midpoint ranges, not audited royalty statements.</p>
          </section>
        )}

        <section aria-labelledby="questions-title">
          <h2 id="questions-title">More Questions About {artist.name}</h2>
          <div class="intent-question-list">
            {intentQuestions.map((item) => (
              <article class="intent-question-card">
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))}
          </div>
        </section>

        <details class="details-card">
          <summary>Show ownership and assumptions</summary>
          <div class="details-card-body">
            <p>{ownershipNote}</p>
            {artist.earnings && (
              <section aria-labelledby="breakdown-title">
                <h2 id="breakdown-title">Supporting Revenue Context</h2>
                <div class="compact-context-grid">
                  {artist.earnings.gross_catalog_revenue && (
                    <div class="compact-context-card"><strong>Estimated gross catalog revenue</strong><span>{artist.earnings.gross_catalog_revenue}</span></div>
                  )}
                  {artist.earnings.artist_or_estate_share && (
                    <div class="compact-context-card"><strong>Estimated artist or estate cut</strong><span>{artist.earnings.artist_or_estate_share}</span></div>
                  )}
                  {artist.earnings.label_share && (
                    <div class="compact-context-card"><strong>Estimated label share</strong><span>{artist.earnings.label_share}</span></div>
                  )}
                  {artist.earnings.publisher_share && (
                    <div class="compact-context-card"><strong>Estimated publisher share</strong><span>{artist.earnings.publisher_share}</span></div>
                  )}
                  {artist.earnings.writer_share && (
                    <div class="compact-context-card"><strong>Estimated writer share</strong><span>{artist.earnings.writer_share}</span></div>
                  )}
                </div>
                {artist.earnings.assumptions && <p class="results-note"><strong>Assumptions:</strong> {artist.earnings.assumptions}</p>}
              </section>
            )}
            {artist.ownership && (
              <section aria-labelledby="ownership-title">
                <h2 id="ownership-title">Ownership and Catalog Status</h2>
                <div class="compact-context-grid">
                  {artist.ownership.master_owner && (
                    <div class="compact-context-card"><strong>Masters</strong><span>{artist.ownership.master_owner}</span></div>
                  )}
                  {artist.ownership.publishing_owner && (
                    <div class="compact-context-card"><strong>Publishing</strong><span>{artist.ownership.publishing_owner}</span></div>
                  )}
                  {artist.ownership.catalog_sale_status && (
                    <div class="compact-context-card"><strong>Catalog sale status</strong><span>{artist.ownership.catalog_sale_status}</span></div>
                  )}
                </div>
                {artist.ownership.notes && <p class="results-note"><strong>Notes:</strong> {artist.ownership.notes}</p>}
              </section>
            )}
            <div class="methodology-card">
              <p class="methodology-badge">{methodology.confidenceLabel}</p>
              <p>{methodology.summary}</p>
              <ul class="meta-list">
                {methodology.bullets.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
              <p>
                <a href={`${baseUrl}insights/methodology/`}>Read the full methodology.</a>
              </p>
            </div>
            <section aria-labelledby="sources-title">
              <h2 id="sources-title">Sources</h2>
              <ul class="meta-list">
                {(article?.sources ?? editorial.sources).map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </section>
          </div>
        </details>

        {(relatedArtists.length > 0 || artist.notable_for || artist.career_highlight || article?.insight || editorial.insight) && (
          <section aria-labelledby="more-context-title" class="song-context-section">
            <h2 id="more-context-title">More Context</h2>
            <div class="context-grid">
              {relatedArtists.length > 0 && (
                <div class="context-card">
                  <h3>Related Artists</h3>
                  <ul class="meta-list">
                    {relatedArtists.map((relatedArtist) => (
                      <li>
                        <a href={`${baseUrl}artist/${relatedArtist.slug}/`}>{relatedArtist.name}</a>
                        <span class="meta-inline">
                          {" "}· {[relatedArtist.genre, relatedArtist.country].filter(Boolean).join(" · ")}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {(artist.notable_for || artist.career_highlight) && (
                <div class="context-card">
                  <h3>Key Career Highlights</h3>
                  <ul class="meta-list">
                    {artist.notable_for && <li><strong>Known for:</strong> {artist.notable_for}</li>}
                    {artist.career_highlight && <li><strong>Highlight:</strong> {artist.career_highlight}</li>}
                  </ul>
                </div>
              )}

              {(article?.insight || editorial.insight) && (
                <div class="context-card">
                  <h3>Editorial Insight</h3>
                  <p>{article?.insight ?? editorial.insight}</p>
                </div>
              )}
            </div>
          </section>
        )}
      </div>

      <aside class="song-sidebar">
        <div class="song-summary-card">
          <p class="eyebrow">Earnings Snapshot</p>
          <h2>{leadRevenue}</h2>
          <ul class="stat-list">
            {artist.genre && <li><strong>Genre:</strong> {artist.genre}</li>}
            {artist.country && <li><strong>Country:</strong> {artist.country}</li>}
            {artist.active_since && <li><strong>Active since:</strong> {artist.active_since}</li>}
            <li><strong>Confidence:</strong> {confidence.level}</li>
          </ul>
        </div>

        {artistSongs.length > 0 && (
          <section aria-labelledby="songs-title">
            <h2 id="songs-title">Top Songs</h2>
            <ul class="meta-list">
              {artistSongs.map((song) => (
                <li>
                  <a href={`${baseUrl}song/${song.slug}/`}>{song.title}</a>
                  {(song.album || song.year) && (
                    <span class="meta-inline">
                      {" "}· {[song.album, song.year].filter(Boolean).join(" · ")}
                    </span>
                  )}
                </li>
              ))}
            </ul>
          </section>
        )}

        {topArtistsByEarnings.length > 0 && (
          <section aria-labelledby="top-artists-title">
            <h2 id="top-artists-title">Top Artists by Earnings</h2>
            <ul class="meta-list">
              {topArtistsByEarnings.map(({ artist: rankedArtist, revenueScore }) => (
                <li>
                  <a href={`${baseUrl}artist/${rankedArtist.slug}/`}>{rankedArtist.name}</a>
                  <span class="meta-inline">
                    {" "}· {formatRevenueMidpoint(revenueScore)}
                  </span>
                </li>
              ))}
            </ul>
          </section>
        )}
      </aside>
    </section>
  </article>
</BaseLayout>
