---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createAlbumArtwork } from "../lib/artistArtwork";
import { albums, getAlbumConfidence } from "../lib/catalog";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const decades = [...new Set(albums.map((album) => (album.year ? `${Math.floor(album.year / 10) * 10}s` : null)).filter(Boolean))].sort();
---

<BaseLayout
  title="Albums | How Much Music"
  description="Browse albums tracked on How Much Music and explore their linked songs."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Albums</p>
      <h1>Albums in the catalog</h1>
      <p>Browse albums derived from the tracked song catalog and jump into linked song pages.</p>
    </div>
    <div class="hero-panel" aria-label="Album count">
      <strong>{albums.length}</strong>
      <span>albums with tracked songs</span>
    </div>
  </section>

  <section aria-labelledby="all-albums-title">
    <h2 id="all-albums-title">Album Directory</h2>
    <div class="filters" data-filter-root="albums">
      <label class="filter-field">
        <span>Search</span>
        <input id="album-search" type="search" placeholder="Search albums or artists" />
      </label>
      <label class="filter-field">
        <span>Decade</span>
        <select id="album-decade">
          <option value="">All decades</option>
          {decades.map((decade) => (
            <option value={decade}>{decade}</option>
          ))}
        </select>
      </label>
      <label class="filter-field">
        <span>Confidence</span>
        <select id="album-confidence">
          <option value="">All confidence levels</option>
          <option value="high">High</option>
          <option value="medium">Medium</option>
          <option value="low">Low</option>
        </select>
      </label>
      <label class="filter-field">
        <span>Sort</span>
        <select id="album-sort">
          <option value="earnings">Highest tracked revenue</option>
          <option value="alpha">Alphabetical</option>
          <option value="year">Newest release year</option>
          <option value="confidence">Highest confidence</option>
        </select>
      </label>
    </div>
    <div class="active-filters" id="album-active-filters"></div>
    <p class="results-note" id="album-results-note">Showing {albums.length} albums</p>
    <div class="card-grid" id="album-card-grid">
      {albums.map((album) => {
        const decade = album.year ? `${Math.floor(album.year / 10) * 10}s` : "";
        const confidence = getAlbumConfidence(album);
        const revenueMidpoint = album.normalizedRevenue?.midpoint ?? 0;
        return (
          <article
            class="card artist-card"
            data-album-card
            data-search={`${album.title} ${album.artistName}`.toLowerCase()}
            data-decade={decade}
            data-confidence={confidence.level}
            data-confidence-score={confidence.score}
            data-revenue={revenueMidpoint}
            data-year={album.year ?? 0}
            data-name={album.title.toLowerCase()}
          >
            <img
              class="artist-card-image album-cover-image"
              src={createAlbumArtwork(album.title, album.artistName, album.slug, {
                releaseDate: album.releaseDate,
                label: album.label,
                trackCount: album.trackCount
              })}
              alt={`Cover artwork for ${album.title} by ${album.artistName}`}
              loading="lazy"
              width="1200"
              height="1200"
            />
            <div class="artist-card-body">
              <p class="eyebrow">Album</p>
              <p class={`confidence-badge confidence-${confidence.level}`}>{confidence.level} confidence</p>
              <h3>
                <a href={`${baseUrl}album/${album.slug}/`}>{album.title}</a>
              </h3>
              <p class="artist-card-meta">
                By <a href={`${baseUrl}artist/${album.artistSlug}/`}>{album.artistName}</a>
              </p>
              <p class="artist-card-meta">
                {[album.releaseDate ?? album.year, album.trackCount ? `${album.trackCount} tracks` : "", `${album.trackedSongCount} tracked song${album.trackedSongCount === 1 ? "" : "s"}`]
                  .filter(Boolean)
                  .join(" · ")}
              </p>
              {album.estimatedRevenue && <p>Tracked song revenue: {album.estimatedRevenue}</p>}
              <p class="artist-card-meta">
                {album.label ?? "Label metadata still partial"} · {album.fullTracklist?.length ? "Full tracklist on album page" : "Tracklist still partial"}
              </p>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const initAlbumFilters = () => {
    const albumSearchInput = document.querySelector("#album-search");
    const albumDecadeSelect = document.querySelector("#album-decade");
    const albumConfidenceSelect = document.querySelector("#album-confidence");
    const albumSortSelect = document.querySelector("#album-sort");
    const albumCards = [...document.querySelectorAll("[data-album-card]")];
    const albumNote = document.querySelector("#album-results-note");
    const albumGrid = document.querySelector("#album-card-grid");
    const activeFilters = document.querySelector("#album-active-filters");

    if (!albumSearchInput || !albumDecadeSelect || !albumConfidenceSelect || !albumSortSelect || !albumNote || !albumGrid || !activeFilters) return;
    if (albumSearchInput.dataset.filtersBound === "true") return;

    const syncUrl = () => {
      const url = new URL(window.location.href);
      const values = {
        q: albumSearchInput.value.trim(),
        decade: albumDecadeSelect.value,
        confidence: albumConfidenceSelect.value,
        sort: albumSortSelect.value
      };

      Object.entries(values).forEach(([key, value]) => {
        if (value) {
          url.searchParams.set(key, value);
        } else {
          url.searchParams.delete(key);
        }
      });

      history.replaceState({}, "", `${url.pathname}${url.searchParams.toString() ? `?${url.searchParams.toString()}` : ""}`);
    };

    const renderActiveFilters = () => {
      const items = [];
      if (albumSearchInput.value.trim()) items.push(`Search: ${albumSearchInput.value.trim()}`);
      if (albumDecadeSelect.value) items.push(`Decade: ${albumDecadeSelect.value}`);
      if (albumConfidenceSelect.value) items.push(`Confidence: ${albumConfidenceSelect.value}`);
      if (albumSortSelect.value && albumSortSelect.value !== "earnings") items.push(`Sort: ${albumSortSelect.selectedOptions[0]?.textContent ?? albumSortSelect.value}`);

      activeFilters.innerHTML = items.length
        ? `${items.map((item) => `<span class="active-filter-chip">${item}</span>`).join("")}<button type="button" class="filter-reset" id="album-reset">Clear filters</button>`
        : "";

      const resetButton = document.querySelector("#album-reset");
      resetButton?.addEventListener("click", () => {
        albumSearchInput.value = "";
        albumDecadeSelect.value = "";
        albumConfidenceSelect.value = "";
        albumSortSelect.value = "earnings";
        applyAlbumFilters();
      }, { once: true });
    };

    const applyAlbumFilters = () => {
      const query = albumSearchInput.value.trim().toLowerCase();
      const decade = albumDecadeSelect.value;
      const confidence = albumConfidenceSelect.value;
      const sort = albumSortSelect.value;

      let visible = 0;

      albumCards.forEach((card) => {
        const matchesQuery = !query || card.dataset.search?.includes(query);
        const matchesDecade = !decade || card.dataset.decade === decade;
        const matchesConfidence = !confidence || card.dataset.confidence === confidence;
        const show = Boolean(matchesQuery && matchesDecade && matchesConfidence);

        card.classList.toggle("is-hidden", !show);
        if (show) visible += 1;
      });

      const sortedCards = [...albumCards].sort((left, right) => {
        if (sort === "alpha") {
          return (left.dataset.name ?? "").localeCompare(right.dataset.name ?? "");
        }

        if (sort === "year") {
          return Number(right.dataset.year ?? 0) - Number(left.dataset.year ?? 0)
            || Number(right.dataset.revenue ?? 0) - Number(left.dataset.revenue ?? 0);
        }

        if (sort === "confidence") {
          return Number(right.dataset.confidenceScore ?? 0) - Number(left.dataset.confidenceScore ?? 0)
            || Number(right.dataset.revenue ?? 0) - Number(left.dataset.revenue ?? 0);
        }

        return Number(right.dataset.revenue ?? 0) - Number(left.dataset.revenue ?? 0)
          || (left.dataset.name ?? "").localeCompare(right.dataset.name ?? "");
      });

      sortedCards.forEach((card) => albumGrid.appendChild(card));

      albumNote.textContent = `Showing ${visible} album${visible === 1 ? "" : "s"}`;
      renderActiveFilters();
      syncUrl();
    };

    const params = new URLSearchParams(window.location.search);
    albumSearchInput.value = params.get("q") ?? "";
    albumDecadeSelect.value = params.get("decade") ?? "";
    albumConfidenceSelect.value = params.get("confidence") ?? "";
    albumSortSelect.value = params.get("sort") ?? "earnings";

    [albumSearchInput, albumDecadeSelect, albumConfidenceSelect, albumSortSelect].forEach((element) => {
      element.addEventListener("input", applyAlbumFilters);
      element.addEventListener("change", applyAlbumFilters);
    });

    albumSearchInput.dataset.filtersBound = "true";
    applyAlbumFilters();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAlbumFilters, { once: true });
  } else {
    initAlbumFilters();
  }

  document.addEventListener("astro:page-load", initAlbumFilters);
</script>
