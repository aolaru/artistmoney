---
import Breadcrumbs from "../components/Breadcrumbs.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { artistMap, songMap } from "../lib/catalog";
import { getCatalogUpdates } from "../lib/updates";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const updates = getCatalogUpdates(30);
const artistTouchCount = updates.reduce((count, entry) => count + entry.artistSlugs.length, 0);
const songTouchCount = updates.reduce((count, entry) => count + entry.songSlugs.length, 0);
const albumTouchCount = updates.filter((entry) => entry.includesAlbumMetadata).length;
const newArtistCount = updates.reduce((count, entry) => count + entry.addedArtistSlugs.length, 0);
const newSongCount = updates.reduce((count, entry) => count + entry.addedSongSlugs.length, 0);
const editorialCount = updates.filter((entry) => entry.includesArtistEditorial || entry.includesSongEditorial).length;

const latestNewArtists = [...new Set(updates.flatMap((entry) => entry.addedArtistSlugs))]
  .map((slug) => artistMap.get(slug))
  .filter(Boolean)
  .slice(0, 6);

const latestNewSongs = [...new Set(updates.flatMap((entry) => entry.addedSongSlugs))]
  .map((slug) => songMap.get(slug))
  .filter(Boolean)
  .slice(0, 6);

const categoryLabels = {
  "catalog-expansion": "Catalog expansion",
  "album-enrichment": "Album enrichment",
  "editorial-upgrade": "Editorial upgrade",
  mixed: "Mixed update"
} as const;
const displayHighlight = (highlight: string) =>
  highlight
    .replaceAll("autopilot", "assisted")
    .replaceAll("Autopilot", "Assisted")
    .replaceAll("generated", "recent")
    .replaceAll("Generated", "Recent")
    .replaceAll("automated", "assisted")
    .replaceAll("Automated", "Assisted");
const displaySummary = (summary: string) => {
  const normalized = summary.toLowerCase();

  if (normalized.includes("expand catalog queue")) return "Expand catalog research queue";
  if (normalized.includes("backfill existing page content")) return "Refresh existing page context";
  if (normalized.includes("daily catalog expansion candidate")) return "Add catalog page candidates";

  return displayHighlight(summary);
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "How Much Music Updates",
  description: "Recent artist, song, and album improvements.",
  url: new URL(`${baseUrl}updates/`, Astro.site).toString()
};
---

<BaseLayout
  title="Updates | How Much Music"
  description="Recent How Much Music artist, song, album, and editorial page improvements."
  jsonLd={jsonLd}
  noindex
>
  <Breadcrumbs items={[{ label: "Home", href: baseUrl }, { label: "Updates" }]} />

  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Updates</p>
      <h1>Editorial change log</h1>
      <p>
        Recent additions and page improvements, grouped by artists, songs, albums, and editorial
        context.
      </p>
    </div>
    <div class="hero-panel" aria-label="Update totals">
      <strong>{updates.length}</strong>
      <span>published page updates</span>
      <span>{newArtistCount} new artists</span>
      <span>{newSongCount} new songs</span>
      <span>{editorialCount} editorial refreshes</span>
      <span>{albumTouchCount} album enrichments</span>
    </div>
  </section>

  <section aria-labelledby="highlights-title">
    <h2 id="highlights-title">Recent Highlights</h2>
    <div class="editorial-grid">
      <article class="card editorial-card">
        <div class="artist-card-body">
          <p class="eyebrow">New Artists</p>
          <h3>{newArtistCount}</h3>
          <p>New artist pages added recently.</p>
          <div class="update-links">
            {latestNewArtists.map((artist) => (
              <span class="active-filter-chip">{artist.name}</span>
            ))}
          </div>
        </div>
      </article>
      <article class="card editorial-card">
        <div class="artist-card-body">
          <p class="eyebrow">New Songs</p>
          <h3>{newSongCount}</h3>
          <p>New song pages with earnings and ownership context.</p>
          <div class="update-links">
            {latestNewSongs.map((song) => (
              <span class="active-filter-chip">{song.title}</span>
            ))}
          </div>
        </div>
      </article>
      <article class="card editorial-card">
        <div class="artist-card-body">
          <p class="eyebrow">Album Enrichments</p>
          <h3>{albumTouchCount}</h3>
          <p>Album metadata, release context, and tracklist improvements.</p>
          <p><a href={`${baseUrl}albums/`}>Browse all albums</a></p>
        </div>
      </article>
      <article class="card editorial-card">
        <div class="artist-card-body">
          <p class="eyebrow">Editorial Refreshes</p>
          <h3>{editorialCount}</h3>
          <p>Artist and song pages improved with clearer copy, metadata, and methodology context.</p>
          <p><a href={`${baseUrl}insights/methodology/`}>Read the methodology</a></p>
        </div>
      </article>
    </div>
  </section>

  <section aria-labelledby="snapshot-title">
    <h2 id="snapshot-title">Update Snapshot</h2>
    <ul class="meta-list">
      <li><strong>Artist pages updated:</strong> {artistTouchCount}</li>
      <li><strong>Song pages updated:</strong> {songTouchCount}</li>
      <li><strong>Album enrichments:</strong> {albumTouchCount}</li>
      <li><strong>Editorial refreshes:</strong> {editorialCount}</li>
    </ul>
  </section>

  <section aria-labelledby="updates-title">
    <h2 id="updates-title">Recent changes</h2>
    {updates.length === 0 ? (
      <p>
        No recent update details are available right now.
      </p>
    ) : (
      <div class="updates-list">
        {updates.map((entry) => {
          const updatedArtistSlugs = entry.artistSlugs.filter((slug) => !entry.addedArtistSlugs.includes(slug));
          const updatedSongSlugs = entry.songSlugs.filter((slug) => !entry.addedSongSlugs.includes(slug));

          return (
            <article class="card update-card">
              <div class="artist-card-body">
                <div class="update-header">
                  <p class="eyebrow">Update</p>
                  <p class="update-date">{entry.date}</p>
                </div>
                <h3>{displaySummary(entry.summary)}</h3>

                <div class="update-tags" aria-label="Update scope">
                  <span class="rank-badge">{categoryLabels[entry.category]}</span>
                  {entry.addedArtistSlugs.length > 0 && (
                    <span class="rank-badge">
                      {entry.addedArtistSlugs.length} new artist page{entry.addedArtistSlugs.length === 1 ? "" : "s"}
                    </span>
                  )}
                  {entry.addedSongSlugs.length > 0 && (
                    <span class="rank-badge">
                      {entry.addedSongSlugs.length} new song page{entry.addedSongSlugs.length === 1 ? "" : "s"}
                    </span>
                  )}
                  {entry.includesAlbumMetadata && <span class="rank-badge">Album metadata</span>}
                  {entry.includesArtistEditorial && <span class="rank-badge">Artist editorial</span>}
                  {entry.includesSongEditorial && <span class="rank-badge">Song editorial</span>}
                </div>

                {entry.highlights.length > 0 && (
                  <>
                    <p class="update-subheading">Highlights</p>
                    <div class="update-tags">
                      {entry.highlights.map((highlight) => (
                        <span class="active-filter-chip">{displayHighlight(highlight)}</span>
                      ))}
                    </div>
                  </>
                )}

                {entry.addedArtistSlugs.length > 0 && (
                  <>
                    <p class="update-subheading">New artist pages</p>
                    <div class="update-links">
                      {entry.addedArtistSlugs.map((slug) => {
                        const artist = artistMap.get(slug);
                        return <span class="active-filter-chip">{artist?.name ?? slug}</span>;
                      })}
                    </div>
                  </>
                )}

                {updatedArtistSlugs.length > 0 && (
                  <>
                    <p class="update-subheading">Updated artist pages</p>
                    <div class="update-links">
                      {updatedArtistSlugs.map((slug) => {
                        const artist = artistMap.get(slug);
                        return <span class="active-filter-chip">{artist?.name ?? slug}</span>;
                      })}
                    </div>
                  </>
                )}

                {entry.addedSongSlugs.length > 0 && (
                  <>
                    <p class="update-subheading">New song pages</p>
                    <div class="update-links">
                      {entry.addedSongSlugs.map((slug) => {
                        const song = songMap.get(slug);
                        return <span class="active-filter-chip">{song?.title ?? slug}</span>;
                      })}
                    </div>
                  </>
                )}

                {updatedSongSlugs.length > 0 && (
                  <>
                    <p class="update-subheading">Updated song pages</p>
                    <div class="update-links">
                      {updatedSongSlugs.map((slug) => {
                        const song = songMap.get(slug);
                        return <span class="active-filter-chip">{song?.title ?? slug}</span>;
                      })}
                    </div>
                  </>
                )}

                {entry.includesAlbumMetadata && (
                  <p class="update-note">
                    This update also changed album metadata, release context, or tracklist coverage.
                    Browse the full album index at <a href={`${baseUrl}albums/`}>Albums</a>.
                  </p>
                )}
              </div>
            </article>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>
