---
import BaseLayout from "../layouts/BaseLayout.astro";
import { artists } from "../lib/catalog";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const slugify = (value: string) =>
  value.toLowerCase().replace(/&/g, "and").replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");

const genreMap = new Map<string, { names: string[]; count: number }>();

artists.forEach((artist) => {
  if (!artist.genre) return;
  const slug = slugify(artist.genre);
  const existing = genreMap.get(slug);

  if (existing) {
    if (!existing.names.includes(artist.genre)) existing.names.push(artist.genre);
    existing.count += 1;
    return;
  }

  genreMap.set(slug, {
    names: [artist.genre],
    count: 1
  });
});

const genres = [...genreMap.entries()]
  .map(([slug, entry]) => ({
    slug,
    name: entry.names[0],
    names: entry.names.sort(),
    count: entry.count
  }))
  .sort((left, right) => left.name.localeCompare(right.name));
---

<BaseLayout title="Genres | Artist Money" description="Browse Artist Money by genre.">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Discovery</p>
      <h1>Browse the catalog by genre</h1>
      <p>Genre pages group artists with similar catalog economics, audience behavior, and playlist context.</p>
    </div>
    <div class="hero-panel" aria-label="Genre count">
      <strong>{genres.length}</strong>
      <span>genres in the catalog</span>
    </div>
  </section>

  <section aria-labelledby="genres-title">
    <h2 id="genres-title">Genres</h2>
    <div class="card-grid">
      {genres.map((genre) => (
        <article class="card">
          <div class="artist-card-body">
            <p class="eyebrow">Genre</p>
            <h3><a href={`${baseUrl}genre/${genre.slug}/`}>{genre.name}</a></h3>
            {genre.names.length > 1 && <p class="artist-card-meta">Includes {genre.names.slice(1).join(" · ")}</p>}
            <p>{genre.count} artist{genre.count === 1 ? "" : "s"} in the catalog</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
