---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getArtistPhotos } from "../lib/artistArtwork";

const titleize = (slug: string) =>
  slug
    .split("-")
    .map((part) => (part.length <= 3 ? part.toUpperCase() : part[0].toUpperCase() + part.slice(1)))
    .join(" ");

const photos = Object.entries(getArtistPhotos()).sort((left, right) => left[0].localeCompare(right[0]));
---

<BaseLayout
  title="Credits | How Much Music"
  description="Image credits, source links, licenses, and rights notes for How Much Music."
>
  <section>
    <p class="eyebrow">Credits</p>
    <h1>Image licensing and hosting</h1>
    <p>
      Artist photos are sourced from Wikimedia Commons where a suitable reusable image is available.
      Each entry lists the source page, license, hosted image reference, and any personality-rights
      caution that still applies.
    </p>
  </section>

  <section aria-labelledby="credits-list-title">
    <h2 id="credits-list-title">Wikimedia Commons images</h2>
    <ul class="meta-list">
      <li>
        <strong>License scope:</strong> These files are reused under the license shown on each
        Wikimedia Commons file page. Attribution and license links should stay attached to the
        reuse context.
      </li>
      <li>
        <strong>Personality rights:</strong> Some photos depict living identifiable people. That
        can still matter even when copyright reuse is allowed, especially for promotional or
        endorsement-like use.
      </li>
      <li>
        <strong>Hosting:</strong> Approved files are served from site assets so image references
        remain stable.
      </li>
    </ul>

    <ul class="meta-list">
      {photos.map(([slug, photo]) => (
        <li>
          <strong>{titleize(slug)}</strong>
          <span class="meta-inline"> · {photo.credit}</span>
          <br />
          <span class="meta-inline">Hosted image available in site assets.</span>
          <br />
          <a href={photo.sourceUrl} rel="noreferrer" target="_blank">Original source page</a>
          <span class="meta-inline"> · </span>
          <a href={photo.licenseUrl} rel="noreferrer" target="_blank">{photo.license}</a>
          {photo.personalityRightsWarning && (
            <>
              <br />
              <strong>Rights warning:</strong>
              <span class="meta-inline"> {photo.personalityRightsWarning}</span>
            </>
          )}
        </li>
      ))}
    </ul>
  </section>

  <section aria-labelledby="fallback-title">
    <h2 id="fallback-title">Fallback artwork</h2>
    <p>
      Artists without an approved Commons photo use simple illustrated artwork. That keeps pages
      visually consistent without introducing uncertain third-party image rights.
    </p>
  </section>
</BaseLayout>
