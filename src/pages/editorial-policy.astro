---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Editorial Policy | How Much Music"
  description="How Much Music's editorial policy for estimates, sources, corrections, and page quality."
>
  <Breadcrumbs items={[{ label: "Home", href: baseUrl }, { label: "Editorial Policy" }]} />

  <section>
    <p class="eyebrow">Editorial Policy</p>
    <h1>How Estimates and Pages Are Reviewed</h1>
    <p>
      How Much Music publishes modeled estimates about music economics. The site does not claim to
      have access to private royalty statements, confidential contracts, distributor dashboards, or
      complete platform-level payout data.
    </p>
  </section>

  <section>
    <h2>What We Publish and Why</h2>
    <div class="editorial-basis-grid">
      <div class="editorial-basis-item">
        <strong>Purpose</strong>
        <span>
          The site explains music catalog economics in plain language: estimated annual ranges,
          rights context, replay demand, and why older songs or artists can still earn.
        </span>
      </div>
      <div class="editorial-basis-item">
        <strong>Publisher</strong>
        <span>
          Pages are published by How Much Music. Reader corrections, source updates, and attribution
          issues should be sent through the contact page.
        </span>
      </div>
      <div class="editorial-basis-item">
        <strong>Evidence Standard</strong>
        <span>
          A page can use structured local catalog data, public platform links, release metadata,
          ownership fields, catalog-sale context, and public references where available.
        </span>
      </div>
      <div class="editorial-basis-item">
        <strong>Limits</strong>
        <span>
          A source can support artist, song, ownership, or platform context without proving the
          displayed revenue range as an audited fact.
        </span>
      </div>
    </div>
  </section>

  <section>
    <h2>Estimate Rules</h2>
    <ul class="meta-list">
      <li>Revenue figures are shown as annual ranges rather than exact totals.</li>
      <li>Artist-side estimates are separated from gross catalog or track revenue when ownership context allows it.</li>
      <li>Pages use confidence labels to show whether the estimate has strong, partial, or limited supporting context.</li>
      <li>Pages with weak original context may be kept available for navigation but excluded from search indexing.</li>
    </ul>
  </section>

  <section>
    <h2>Source Handling</h2>
    <p>
      The site favors public, checkable context: official artist and platform pages, public catalog
      sale reporting, rights and licensing notes, platform signals, release metadata, and reusable
      image-license pages. A source can support context without making the displayed revenue range
      an audited fact.
    </p>
  </section>

  <section>
    <h2>Publication and Indexing Gate</h2>
    <p>
      Not every catalog record is treated as an indexable article. Artist and song pages are included
      in the public sitemap only after they have an editorial article entry with page-specific
      context. Utility directories, incomplete catalog profiles, update logs, album pages, and broad
      browsing pages can remain available for navigation while being excluded from search indexing.
    </p>
  </section>

  <section>
    <h2>What We Do Not Treat as Proof</h2>
    <ul class="meta-list">
      <li>A high stream count does not prove one universal per-stream payout rate.</li>
      <li>A catalog sale mention does not prove the artist personally receives the whole sale value.</li>
      <li>An official music or platform page confirms identity and availability, not complete royalty income.</li>
      <li>Modeled estimates are not substitutes for royalty statements, contracts, audits, or distributor dashboards.</li>
    </ul>
  </section>

  <section>
    <h2>Corrections</h2>
    <p>
      Corrections are reviewed when a public source shows that a page has outdated ownership
      context, incorrect release information, broken image attribution, or a materially misleading
      estimate. Send corrections through the contact page.
    </p>
  </section>

  <section>
    <h2>Advertising Separation</h2>
    <p>
      Advertising does not determine which artists, songs, albums, or estimates are included. Pages
      are selected and updated according to editorial relevance, available context, and catalog
      research value.
    </p>
  </section>
</BaseLayout>
