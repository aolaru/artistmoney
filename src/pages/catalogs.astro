---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createAlbumArtwork } from "../lib/artistArtwork";
import { rankedAlbums } from "../lib/catalog";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const entries = rankedAlbums.filter((entry) => entry.revenueRange).slice(0, 25);
---

<BaseLayout
  title="Top Catalogs | Artist Money"
  description="Ranked albums and catalogs by the modeled revenue of tracked songs."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Rankings</p>
      <h1>Top catalogs from tracked songs</h1>
      <p>
        This ranking aggregates the annual revenue estimates of songs currently tracked on each
        album page. It is a catalog proxy, not a full royalty statement for the entire release.
      </p>
    </div>
    <div class="hero-panel" aria-label="Ranked catalog count">
      <strong>{entries.length}</strong>
      <span>albums with aggregated revenue ranges</span>
    </div>
  </section>

  <section aria-labelledby="catalogs-title">
    <h2 id="catalogs-title">Catalog Ranking</h2>
    <div class="card-grid">
      {entries.map(({ album, revenueRange }, index) => (
        <article class="card artist-card ranked-card">
          <img
            class="artist-card-image album-cover-image"
            src={createAlbumArtwork(album.title, album.artistName, album.slug, {
              releaseDate: album.releaseDate,
              label: album.label,
              trackCount: album.trackCount
            })}
            alt={`Cover artwork for ${album.title} by ${album.artistName}`}
            loading="lazy"
            width="1200"
            height="1200"
          />
          <div class="artist-card-body">
            <p class="rank-badge">#{index + 1}</p>
            <p class="eyebrow">Album</p>
            <h3><a href={`${baseUrl}album/${album.slug}/`}>{album.title}</a></h3>
            <p class="artist-card-meta">
              By <a href={`${baseUrl}artist/${album.artistSlug}/`}>{album.artistName}</a>
            </p>
            <p class="artist-card-meta">
              {[album.releaseDate ?? album.year, album.trackCount ? `${album.trackCount} tracks` : "", `${album.trackedSongCount} tracked songs`]
                .filter(Boolean)
                .join(" · ")}
            </p>
            <p>Tracked annual revenue: {album.estimatedRevenue ?? "Not enough structured revenue yet"}</p>
            {revenueRange && (
              <p class="artist-card-meta">
                Modeled midpoint: {Math.round((revenueRange.min + revenueRange.max) / 2).toLocaleString("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 })}
              </p>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
