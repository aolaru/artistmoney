---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { songArticles } from "../../data/songArticles";
import { createSongArtwork } from "../../lib/artistArtwork";
import { getAlbum, getAlbumSlug, getArtist, getSongMethodology, songs, type Song } from "../../lib/catalog";
import { getSongEditorial } from "../../lib/editorial";

export function getStaticPaths() {
  return songs.map((song) => ({
    params: { slug: song.slug },
    props: { song }
  }));
}

const { song } = Astro.props as { song: Song };
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const artist = getArtist(song.artist);
const album = song.album ? getAlbum(getAlbumSlug(song.artist, song.album)) : undefined;
const relatedSongs = (song.related_songs?.length
  ? song.related_songs
      .map((slug) => songs.find((entry) => entry.slug === slug))
      .filter(Boolean)
  : songs.filter((entry) => entry.artist === song.artist && entry.slug !== song.slug).slice(0, 3)) as Song[];
const article = songArticles[song.slug];
const hasDetailedEarnings = Boolean(song.earnings || song.ownership);
const providerArtwork = song.player?.artwork;
const providerArtworkLink = song.player?.links?.appleMusic ?? song.player?.appleMusic;
const imageSrc = providerArtwork ?? createSongArtwork(song.title, artist?.name ?? song.artist, song.slug, {
  year: song.year,
  album: song.album
});
const playerLinks = Object.entries(song.player?.links ?? {}).filter(([, url]) => url) as Array<[string, string]>;
const editorial = getSongEditorial(song, artist);
const methodology = getSongMethodology(song);
const songSchema = {
  "@context": "https://schema.org",
  "@type": "MusicRecording",
  name: song.title,
  url: new URL(`${baseUrl}song/${song.slug}/`, Astro.site).toString(),
  image: imageSrc,
  byArtist: artist
    ? {
        "@type": "MusicGroup",
        name: artist.name,
        url: new URL(`${baseUrl}artist/${artist.slug}/`, Astro.site).toString()
      }
    : undefined,
  inAlbum: song.album
    ? {
        "@type": "MusicAlbum",
        name: song.album
      }
    : undefined,
  datePublished: song.year ? `${song.year}` : undefined,
  description:
    song.meaning_summary ??
    article?.shortAnswer ??
    `${song.title} song page with earnings estimates and catalog insights on How Much Music.`
};
---

<BaseLayout
  title={article?.seoTitle ?? `${song.title} | How Much Music`}
  description={article?.shortAnswer ?? `${song.title} meaning, earnings, and insights on How Much Music.`}
  image={imageSrc}
  imageAlt={artist ? `${song.title} by ${artist.name}` : song.title}
  type="article"
  jsonLd={songSchema}
>
  <article>
    <Breadcrumbs items={[
      { label: "Home", href: baseUrl },
      { label: "Songs", href: `${baseUrl}songs/` },
      { label: song.title }
    ]} />

    <p class="eyebrow">Song</p>
    <h1>{song.title}</h1>

    <div class="song-visual">
      <img
        class="song-visual-image"
        src={imageSrc}
        alt={artist ? `${song.title} by ${artist.name}` : song.title}
        width="1200"
        height="675"
        referrerpolicy="no-referrer"
      />
    </div>
    {providerArtwork && (
      <p class="image-credit">
        Artwork shown via Apple Music.
        {" "}
        {providerArtworkLink && (
          <a href={providerArtworkLink} rel="noreferrer" target="_blank">
            Open the source track
          </a>
        )}
      </p>
    )}

    {(song.album || song.year) && (
      <ul class="meta-list">
        {song.album && (
          <li>
            <strong>Album:</strong>{" "}
            {album ? <a href={`${baseUrl}album/${album.slug}/`}>{song.album}</a> : song.album}
          </li>
        )}
        {song.year && <li><strong>Released:</strong> {song.year}</li>}
      </ul>
    )}

    <section aria-labelledby="song-artist-title">
      <h2 id="song-artist-title">Artist</h2>
      <p>
        {artist ? <a href={`${baseUrl}artist/${artist.slug}/`}>{artist.name}</a> : song.artist}
      </p>
    </section>

    {(song.player?.previewUrl || playerLinks.length > 0) && (
      <section aria-labelledby="player-title">
        <h2 id="player-title">Listen</h2>
        {song.player?.previewUrl ? (
          <>
            <p class="results-note">Official Apple Music preview.</p>
            <audio class="song-player" controls preload="none" src={song.player.previewUrl}>
              Your browser does not support the audio element.
            </audio>
          </>
        ) : (
          <p class="results-note">Preview audio is not available for this song right now.</p>
        )}
        {playerLinks.length > 0 && (
          <div class="external-links">
            {playerLinks.map(([platform, url]) => (
              <a class="external-link" href={url} rel="noreferrer" target="_blank">
                {platform === "appleMusic"
                  ? "Apple Music"
                  : platform === "youtubeMusic"
                    ? "YouTube Music"
                    : platform === "amazonMusic"
                      ? "Amazon Music"
                      : "Spotify"}
              </a>
            ))}
          </div>
        )}
      </section>
    )}

    <section aria-labelledby="meaning-title">
      <h2 id="meaning-title">Meaning</h2>
      <p>{song.meaning_summary ?? editorial.meaning}</p>
    </section>

    <section aria-labelledby="short-answer-title">
      <h2 id="short-answer-title">Short Answer</h2>
      <p><strong>{article?.shortAnswer ?? editorial.shortAnswer}</strong></p>
    </section>

    {hasDetailedEarnings ? (
      <>
        <section aria-labelledby="earnings-title">
          <h2 id="earnings-title">Estimated Artist-Side Annual Earnings</h2>
          <ul class="meta-list">
            <li>{song.earnings?.artist_or_estate_share ?? song.estimated_revenue}</li>
          </ul>
        </section>

        {song.earnings && (
          <section aria-labelledby="breakdown-title">
            <h2 id="breakdown-title">Revenue Breakdown</h2>
            <ul class="meta-list">
              {song.earnings.gross_track_revenue && (
                <li><strong>Estimated gross track revenue:</strong> {song.earnings.gross_track_revenue}</li>
              )}
              {song.earnings.artist_or_estate_share && (
                <li><strong>Estimated artist-side cut:</strong> {song.earnings.artist_or_estate_share}</li>
              )}
              {song.earnings.label_master_share && (
                <li><strong>Estimated label master share:</strong> {song.earnings.label_master_share}</li>
              )}
              {song.earnings.publishing_share && (
                <li><strong>Estimated publishing share:</strong> {song.earnings.publishing_share}</li>
              )}
              {song.earnings.songwriter_share && (
                <li><strong>Estimated songwriter share:</strong> {song.earnings.songwriter_share}</li>
              )}
              {song.earnings.assumptions && (
                <li><strong>Assumptions:</strong> {song.earnings.assumptions}</li>
              )}
            </ul>
          </section>
        )}

        {song.ownership && (
          <section aria-labelledby="ownership-title">
            <h2 id="ownership-title">Ownership and Catalog Status</h2>
            <ul class="meta-list">
              {song.ownership.master_owner && (
                <li><strong>Masters:</strong> {song.ownership.master_owner}</li>
              )}
              {song.ownership.publishing_owner && (
                <li><strong>Publishing:</strong> {song.ownership.publishing_owner}</li>
              )}
              {song.ownership.catalog_sale_status && (
                <li><strong>Catalog sale status:</strong> {song.ownership.catalog_sale_status}</li>
              )}
              {song.ownership.notes && (
                <li><strong>Notes:</strong> {song.ownership.notes}</li>
              )}
            </ul>
          </section>
        )}
      </>
    ) : (
      <>
        <section aria-labelledby="breakdown-title">
          <h2 id="breakdown-title">Earnings Breakdown</h2>
          <ul class="meta-list">
            {(article?.breakdown ?? [
              ...editorial.breakdown
            ]).map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </section>

        <section aria-labelledby="earnings-title">
          <h2 id="earnings-title">Estimated Earnings</h2>
          <ul class="meta-list">
            <li>{song.estimated_revenue}</li>
          </ul>
        </section>
      </>
    )}

    <section aria-labelledby="lifetime-title">
      <h2 id="lifetime-title">Lifetime Earnings</h2>
      <p><strong>{article?.lifetimeEstimate ?? editorial.lifetime}</strong></p>
    </section>

    <section aria-labelledby="money-title">
      <h2 id="money-title">Why It Still Makes Money</h2>
      <ul class="meta-list">
        {(song.revenue_drivers ?? article?.whyItStillMakesMoney ?? [
          ...editorial.why
        ]).map((point) => (
          <li>{point}</li>
        ))}
      </ul>
    </section>

    <section aria-labelledby="insight-title">
      <h2 id="insight-title">Insight</h2>
      <p>{article?.insight ?? editorial.insight}</p>
    </section>

    {relatedSongs.length > 0 && (
      <section aria-labelledby="related-title">
        <h2 id="related-title">Related Songs</h2>
        <ul class="meta-list">
          {relatedSongs.map((relatedSong) => (
            <li>
              <a href={`${baseUrl}song/${relatedSong.slug}/`}>{relatedSong.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section aria-labelledby="methodology-title">
      <h2 id="methodology-title">Methodology</h2>
      <div class="methodology-card">
        <p class="methodology-badge">{methodology.confidenceLabel}</p>
        <p>{methodology.summary}</p>
        <ul class="meta-list">
          {methodology.bullets.map((point) => (
            <li>{point}</li>
          ))}
        </ul>
        <p>
          <a href={`${baseUrl}insights/methodology/`}>Read the full methodology.</a>
        </p>
      </div>
    </section>
  </article>
</BaseLayout>
