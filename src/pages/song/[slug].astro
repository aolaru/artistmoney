---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { songArticles } from "../../data/songArticles";
import { createSongArtwork } from "../../lib/artistArtwork";
import {
  getAlbum,
  getAlbumSlug,
  getArtist,
  getConfidenceSummary,
  getContextSongs,
  getMoreSongsFromAlbum,
  getRelatedAlbumsForSong,
  getSongConfidence,
  getSongMethodology,
  getSongOwnershipNote,
  rankedSongs,
  songs,
  type Song
} from "../../lib/catalog";
import { getSongEditorial } from "../../lib/editorial";
import { formatFreshnessDate, getLatestGitDate } from "../../lib/freshness";
import { getSongReviewReferences, isSongReviewReady } from "../../lib/reviewReady";
import { formatRevenueMidpoint } from "../../lib/revenue";

export function getStaticPaths() {
  return songs.map((song) => ({
    params: { slug: song.slug },
    props: { song }
  }));
}

const { song } = Astro.props as { song: Song };
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const artist = getArtist(song.artist);
const album = song.album ? getAlbum(getAlbumSlug(song.artist, song.album)) : undefined;
const relatedSongs = (song.related_songs?.length
  ? song.related_songs
      .map((slug) => songs.find((entry) => entry.slug === slug))
      .filter(Boolean)
  : songs.filter((entry) => entry.artist === song.artist && entry.slug !== song.slug).slice(0, 3)) as Song[];
const article = songArticles[song.slug];
const hasDetailedEarnings = Boolean(song.earnings || song.ownership);
const providerArtwork = song.player?.artwork;
const providerArtworkLink = song.player?.links?.appleMusic ?? song.player?.appleMusic;
const imageSrc = providerArtwork ?? createSongArtwork(song.title, artist?.name ?? song.artist, song.slug, {
  year: song.year,
  album: song.album
});
const playerLinks = Object.entries(song.player?.links ?? {}).filter(([, url]) => url) as Array<[string, string]>;
const editorial = getSongEditorial(song, artist);
const methodology = getSongMethodology(song);
const confidence = getSongConfidence(song);
const ownershipNote = getSongOwnershipNote(song, artist);
const moreFromAlbum = getMoreSongsFromAlbum(song, 4);
const relatedAlbums = getRelatedAlbumsForSong(song, 3);
const contextSongs = getContextSongs(song, 4);
const leadRevenue = song.earnings?.artist_or_estate_share ?? song.estimated_revenue;
const conciseWhy = (song.revenue_drivers ?? article?.whyItStillMakesMoney ?? [...editorial.why]).slice(0, 3);
const detailedBreakdown = article?.breakdown ?? [...editorial.breakdown];
const comparisonSongs = rankedSongs
  .filter((entry) => entry.song.slug !== song.slug)
  .map((entry) => {
    const entrySongArtist = getArtist(entry.song.artist);
    const sameArtist = entry.song.artist === song.artist;
    const sameAlbum = Boolean(song.album && entry.song.album && song.album === entry.song.album);
    const sameYear = song.year && entry.song.year ? Math.abs(entry.song.year - song.year) <= 2 : false;
    const sameGenre = artist?.genre && entrySongArtist?.genre && artist.genre === entrySongArtist.genre;
    const yearDistance = song.year && entry.song.year ? Math.abs(entry.song.year - song.year) : 99;
    const revenueDistance = Math.abs(
      (entry.song.normalizedRevenue?.artistSide?.midpoint ?? 0) - (song.normalizedRevenue?.artistSide?.midpoint ?? 0)
    );

    let relevance = 0;
    const reasons: string[] = [];

    if (sameArtist) {
      relevance += 8;
      reasons.push("same artist");
    }
    if (sameAlbum) {
      relevance += 5;
      reasons.push("same album");
    }
    if (sameGenre) {
      relevance += 3;
      reasons.push("same genre");
    }
    if (sameYear) {
      relevance += Math.max(1, 3 - yearDistance);
      reasons.push("same era");
    }
    if (revenueDistance > 0 && revenueDistance <= 500_000) {
      relevance += 2;
      reasons.push("similar earnings band");
    }

    return {
      ...entry,
      relevance,
      comparisonReason: reasons.slice(0, 2).join(" · ")
    };
  })
  .filter((entry) => entry.relevance > 0)
  .sort((left, right) =>
    right.relevance - left.relevance ||
    Math.abs(left.revenueScore - (song.normalizedRevenue?.artistSide?.midpoint ?? 0)) -
      Math.abs(right.revenueScore - (song.normalizedRevenue?.artistSide?.midpoint ?? 0))
  )
  .slice(0, 3);
const songRank = rankedSongs.findIndex((entry) => entry.song.slug === song.slug) + 1;
const catalogPercentile = songRank > 0 ? Math.max(1, Math.round((songRank / rankedSongs.length) * 100)) : undefined;
const yearsOld = song.year ? new Date().getFullYear() - song.year : undefined;
const artistSongCount = songs.filter((entry) => entry.artist === song.artist).length;
const artistRank = rankedSongs
  .filter((entry) => entry.song.artist === song.artist)
  .findIndex((entry) => entry.song.slug === song.slug) + 1;
const snippetQuestion = `How much money does ${song.title} make?`;
const snippetLead = hasDetailedEarnings
  ? `${song.title}${artist ? ` by ${artist.name}` : ""} is modeled at ${leadRevenue} per year on the artist side, with gross track revenue and ownership context separated below.`
  : `${song.title}${artist ? ` by ${artist.name}` : ""} earns an estimated ${leadRevenue} per year from streaming, licensing, and long-tail catalog replay value.`;
const snippetSupport = yearsOld && yearsOld >= 10
  ? `The song still reads as an evergreen catalog asset roughly ${yearsOld} years after release.`
  : artistRank > 0 && artistSongCount > 1
    ? `It currently ranks #${artistRank} among the tracked songs for ${artist?.name ?? song.artist}.`
    : `This page focuses on the annual earnings range rather than claiming an audited lifetime total.`;
const takeaway = hasDetailedEarnings
  ? `${song.title} is one of the stronger modeled catalog earners here because replay demand and ownership context both support a durable annual range.`
  : `${song.title} keeps earning because it still shows up in long-tail streaming, playlist rotation, and broader catalog memory.`;
const statItems = [
  songRank > 0 ? `Currently ranks around the top ${catalogPercentile}% of tracked songs by modeled artist-side earnings` : undefined,
  song.year ? `Released in ${song.year}${yearsOld ? ` and still shows earnings power roughly ${yearsOld} years later` : ""}` : undefined,
  artistRank > 0 && artistSongCount > 1 ? `Ranks #${artistRank} among ${artistSongCount} tracked songs for ${artist?.name ?? song.artist}` : undefined,
  album?.trackCount ? `${album.trackCount} tracks on the linked album page` : undefined,
  song.player?.previewUrl ? "Apple Music preview available" : "External listening links available",
  `${confidence.level} confidence estimate`
].filter(Boolean);
const revenueBarCandidates = [
  song.normalizedRevenue?.grossTrack
    ? {
        label: "Gross track revenue",
        value: song.earnings?.gross_track_revenue ?? song.normalizedRevenue.grossTrack.display,
        midpoint: song.normalizedRevenue.grossTrack.midpoint
      }
    : undefined,
  song.normalizedRevenue?.artistSide
    ? {
        label: "Artist-side share",
        value: song.earnings?.artist_or_estate_share ?? song.normalizedRevenue.artistSide.display,
        midpoint: song.normalizedRevenue.artistSide.midpoint
      }
    : undefined,
  song.earnings?.label_master_share
    ? {
        label: "Label master share",
        value: song.earnings.label_master_share,
        midpoint: song.normalizedRevenue?.grossTrack?.midpoint && song.normalizedRevenue?.artistSide?.midpoint
          ? Math.max(song.normalizedRevenue.grossTrack.midpoint - song.normalizedRevenue.artistSide.midpoint, 0)
          : 0
      }
    : undefined
].filter(Boolean);
const revenueBarsMax = Math.max(...revenueBarCandidates.map((entry) => entry.midpoint), 0);
const revenueBars = revenueBarCandidates.map((entry) => ({
  ...entry,
  width: revenueBarsMax > 0 ? Math.max(18, Math.round((entry.midpoint / revenueBarsMax) * 100)) : 100
}));
const numberFormatter = new Intl.NumberFormat("en-US");
const platformMetrics = song.platformMetrics;
const youtubeSourceLabels = {
  official_video: "Official video",
  official_audio: "Official audio",
  lyric_video: "Lyric video",
  topic: "YouTube topic"
};
const youtubeVideoUrl = platformMetrics?.youtubeVideoId
  ? `https://www.youtube.com/watch?v=${platformMetrics.youtubeVideoId}`
  : undefined;
const spotifyTrackUrl = platformMetrics?.spotifyTrackId
  ? `https://open.spotify.com/track/${platformMetrics.spotifyTrackId}`
  : song.player?.links?.spotify;
const hasPlatformSignals = Boolean(
  platformMetrics?.spotifyPopularity !== undefined ||
  platformMetrics?.youtubeViews !== undefined ||
  platformMetrics?.spotifyTrackId ||
  platformMetrics?.youtubeVideoId
);
const generatedEvidenceItems = [
  song.earnings?.gross_track_revenue && song.earnings?.artist_or_estate_share
    ? `Internal song data separates gross track revenue (${song.earnings.gross_track_revenue}) from modeled artist-side share (${song.earnings.artist_or_estate_share}).`
    : leadRevenue
      ? `Internal song data lists a modeled annual earnings range of ${leadRevenue}.`
      : undefined,
  song.earnings?.publishing_share || song.earnings?.songwriter_share
    ? `Publishing and songwriter lanes are shown separately where available: ${[
        song.earnings?.publishing_share ? `publishing ${song.earnings.publishing_share}` : undefined,
        song.earnings?.songwriter_share ? `songwriter ${song.earnings.songwriter_share}` : undefined
      ].filter(Boolean).join("; ")}.`
    : undefined,
  song.ownership
    ? `Ownership fields on this page include ${[
        song.ownership.master_owner ? "master context" : undefined,
        song.ownership.publishing_owner ? "publishing context" : undefined,
        song.ownership.catalog_sale_status ? "catalog-sale status" : undefined
      ].filter(Boolean).join(", ")}.`
    : undefined,
  artist
    ? `Catalog metadata links the recording to ${artist.name}${song.album ? `, ${song.album}` : ""}${song.year ? `, ${song.year}` : ""}.`
    : undefined,
  hasPlatformSignals
    ? "Configured Spotify or YouTube identifiers are used as public platform context when available."
    : playerLinks.length > 0
      ? "External listening links are used as public track-identity references."
      : undefined
].filter(Boolean);
const generatedMethodologyNotes = [
  "The estimate is a modeled annual range, not a public royalty statement.",
  hasDetailedEarnings
    ? "Gross track revenue, artist-side share, label share, publishing, and songwriter lanes are separated only where the page has structured split data."
    : "When detailed split data is unavailable, the page stays with a single directional earnings range.",
  "Platform, certification, and listening links are context signals; they are not converted directly into royalty totals.",
  "Per-stream payouts vary by platform, territory, subscription tier, and rights contract, so this page does not claim one universal song rate."
];
const evidenceItems = article?.evidence?.length ? article.evidence : generatedEvidenceItems;
const methodologyNotes = article?.methodologyNotes?.length ? article.methodologyNotes : generatedMethodologyNotes;
const modelNotes = [
  song.ownership?.notes ? `Ownership note: ${song.ownership.notes}` : undefined,
  hasPlatformSignals ? "Public platform signals are included where Spotify or YouTube identifiers are configured." : undefined
].filter(Boolean);
const isReviewReady = isSongReviewReady(song);
const allReferenceLinks = getSongReviewReferences(song);
const hasSourceContext = Boolean(
  evidenceItems.length ||
  methodologyNotes.length ||
  modelNotes.length ||
  allReferenceLinks.length
);
const intentQuestions = [
  {
    question: `How much did ${song.title} make in total?`,
    answer:
      article?.lifetimeEstimate
        ? `${song.title} is currently modeled at ${article.lifetimeEstimate} in lifetime earnings, based on the annual range and long-tail replay assumptions shown on this page.`
        : `${song.title} does not have a public lifetime total, so this page stays focused on modeled annual earnings instead of claiming an audited career total.`
  },
  {
    question: `How much does ${song.title} make per stream?`,
    answer: `${song.title} does not have a single public per-stream rate because payouts vary by platform, territory, subscription tier, and contract structure. The estimate here is modeled from aggregate streaming, licensing, and catalog behavior instead.`
  },
  {
    question: `Who owns ${song.title}?`,
    answer: ownershipNote
  }
];
const topEarningSongs = rankedSongs
  .filter((entry) => entry.song.slug !== song.slug)
  .slice(0, 5);
const lastUpdatedDate = getLatestGitDate([
  `src/data/songs/${song.slug}.json`,
  "src/data/songMetadata.ts",
  "src/data/songArticles.ts",
  "src/data/platformMetrics.ts",
  "src/pages/song/[slug].astro"
]);
const lastUpdated = formatFreshnessDate(lastUpdatedDate);
const trafficMagnetNote = songRank > 0 && catalogPercentile
  ? `${song.title} sits in the top ${catalogPercentile}% of tracked songs on the site by modeled artist-side earnings.`
  : `${song.title} is positioned here using the same catalog ranking model applied across the site.`;
const songTrustItems = [
  { label: "Modeled artist-side range", value: leadRevenue },
  { label: "Gross track revenue", value: song.earnings?.gross_track_revenue ?? "Not separated on this page" },
  { label: "Ownership context", value: song.ownership ? "Included below" : "High-level only" },
  {
    label: "Platform signals",
    value: hasPlatformSignals ? "Included below" : "Listening links only"
  },
  { label: "Last updated", value: lastUpdated ?? "Current build" }
];
const editorialBasisItems = [
  {
    label: "Article status",
    value: "Article-backed estimate with page-specific context."
  },
  {
    label: "How the range is framed",
    value: hasDetailedEarnings
      ? "Structured track splits separate gross revenue, artist-side share, and rights-owner lanes where available."
      : "A modeled annual range is shown only as directional song context."
  },
  {
    label: "What the page does not claim",
    value: "No private royalty statement, contract, distributor dashboard, or platform payout file is used as proof."
  },
  {
    label: "Correction path",
    value: "Public corrections are handled through the contact page when a source shows outdated or misleading context."
  }
];
const metadataBits = [
  artist ? artist.name : song.artist,
  song.album ? song.album : undefined,
  song.year ? `${song.year}` : undefined
].filter(Boolean);
const songSchema = {
  "@context": "https://schema.org",
  "@type": "MusicRecording",
  name: song.title,
  url: new URL(`${baseUrl}song/${song.slug}/`, Astro.site).toString(),
  image: imageSrc,
  byArtist: artist
    ? {
        "@type": "MusicGroup",
        name: artist.name,
        url: new URL(`${baseUrl}artist/${artist.slug}/`, Astro.site).toString()
      }
    : undefined,
  inAlbum: song.album
    ? {
        "@type": "MusicAlbum",
        name: song.album
      }
    : undefined,
  datePublished: song.year ? `${song.year}` : undefined,
  description:
    song.meaning_summary ??
    article?.shortAnswer ??
    `${song.title} song page with earnings estimates and catalog insights on How Much Music.`
};
const articleSchema = isReviewReady && article
  ? {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: article.seoTitle,
      description: article.shortAnswer,
      url: new URL(`${baseUrl}song/${song.slug}/`, Astro.site).toString(),
      image: imageSrc,
      author: {
        "@type": "Organization",
        name: "How Much Music"
      },
      publisher: {
        "@type": "Organization",
        name: "How Much Music",
        url: new URL(baseUrl, Astro.site).toString()
      },
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": new URL(`${baseUrl}song/${song.slug}/`, Astro.site).toString()
      },
      dateModified: lastUpdatedDate,
      about: {
        "@type": "MusicRecording",
        name: song.title,
        byArtist: artist
          ? {
              "@type": "MusicGroup",
              name: artist.name,
              url: new URL(`${baseUrl}artist/${artist.slug}/`, Astro.site).toString()
            }
          : {
              "@type": "MusicGroup",
              name: song.artist
            }
      },
      isAccessibleForFree: true
    }
  : undefined;
const pageJsonLd = articleSchema ? [songSchema, articleSchema] : songSchema;
---

<BaseLayout
  title={article?.seoTitle ?? `${song.title} | How Much Music`}
  description={article?.shortAnswer ?? `${song.title} meaning, earnings, and insights on How Much Music.`}
  image={imageSrc}
  imageAlt={artist ? `${song.title} by ${artist.name}` : song.title}
  type="article"
  jsonLd={pageJsonLd}
  noindex={!isReviewReady}
>
  <article>
    <Breadcrumbs items={[
      { label: "Home", href: baseUrl },
      { label: "Songs", href: `${baseUrl}songs/` },
      { label: song.title }
    ]} />

    <section class="song-page-shell" aria-labelledby="song-title">
      <div class="song-primary-flow">
        <p class="eyebrow">Song</p>
        <h1 id="song-title">{song.title}</h1>
        {metadataBits.length > 0 && <p class="song-kicker">{metadataBits.join(" · ")}</p>}
        <p class={`confidence-badge confidence-${confidence.level}`}>{confidence.level} confidence</p>
        <section class="trust-snapshot" aria-label="Page trust snapshot">
          <p class="confidence-note">
            {getConfidenceSummary(confidence)}
            {" "}
            <a href={`${baseUrl}insights/methodology/`}>Why?</a>
          </p>
          <p class="trust-summary">{methodology.summary}</p>
          <div class="trust-points">
            {songTrustItems.map((item) => (
              <div class="trust-point">
                <strong>{item.label}</strong>
                <span>{item.value}</span>
              </div>
            ))}
          </div>
        </section>

        <div class="song-visual">
          <img
            class="song-visual-image"
            src={imageSrc}
            alt={artist ? `${song.title} by ${artist.name}` : song.title}
            width="1200"
            height="675"
            referrerpolicy="no-referrer"
          />
        </div>

        {providerArtwork && (
          <p class="image-credit">
            Artwork shown via Apple Music.
            {" "}
            {providerArtworkLink && (
              <a href={providerArtworkLink} rel="noreferrer" target="_blank">
                Open the source track
              </a>
            )}
          </p>
        )}

        {article && (
          <section class="editorial-basis-card" aria-labelledby="song-editorial-basis-title">
            <div class="editorial-basis-heading">
              <p class="eyebrow">Editorial Basis</p>
              <h2 id="song-editorial-basis-title">How this estimate should be read</h2>
              <p>
                This page is designed to answer one narrow question: how {song.title}
                {artist ? ` by ${artist.name}` : ""} is modeled as a catalog asset. The estimate is
                presented as a documented range, not as a verified royalty total.
              </p>
            </div>
            <div class="editorial-basis-grid">
              {editorialBasisItems.map((item) => (
                <div class="editorial-basis-item">
                  <strong>{item.label}</strong>
                  <span>{item.value}</span>
                </div>
              ))}
            </div>
            <p class="results-note">
              See the <a href={`${baseUrl}editorial-policy/`}>Editorial Policy</a> for the site-wide
              source and correction rules.
            </p>
          </section>
        )}

        <section aria-labelledby="short-answer-title" class="song-intro-card">
          <h2 id="short-answer-title">Short Answer</h2>
          <p class="seo-question"><strong>{snippetQuestion}</strong></p>
          <p class="song-lead-answer"><strong>{snippetLead}</strong></p>
          <p class="song-takeaway"><strong>Takeaway:</strong> {takeaway}</p>
          <p>{song.meaning_summary ?? editorial.meaning}</p>

          <div class="song-intro-grid">
            <div class="song-intro-panel">
              <h3>Did You Know?</h3>
              <ul class="song-bullet-list">
                {statItems.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>

            <div class="song-intro-panel">
              <h3>Why It Still Works</h3>
              <ul class="song-bullet-list">
                {conciseWhy.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
          </div>

          <p class="traffic-magnet-note">{trafficMagnetNote}</p>
          <div class="song-intro-footer">
            <p class="results-note">{snippetSupport}</p>
            {lastUpdated && <p class="results-note">Last updated: {lastUpdated}</p>}
          </div>
        </section>

        {isReviewReady && allReferenceLinks.length > 0 && (
          <section class="editorial-basis-card source-snapshot-card" aria-labelledby="source-snapshot-title">
            <div class="editorial-basis-heading">
              <p class="eyebrow">Key Sources</p>
              <h2 id="source-snapshot-title">Public context used on this page</h2>
              <p>
                These links support track identity, platform context, release context, or public
                catalog signals. They do not prove the modeled royalty range by themselves.
              </p>
            </div>
            <div class="reference-list source-snapshot-list">
              {allReferenceLinks.slice(0, 3).map((reference) => (
                <article class="reference-item">
                  <h3><a href={reference.url} rel="noreferrer" target="_blank">{reference.label}</a></h3>
                  <p>{reference.note}</p>
                </article>
              ))}
            </div>
            <p class="results-note"><a href="#sources-title">Read the full source notes.</a></p>
          </section>
        )}

        {comparisonSongs.length > 0 && (
          <section aria-labelledby="comparison-title" class="comparison-section">
            <h2 id="comparison-title">How It Compares</h2>
            <p class="comparison-summary">
              {song.title} is compared against nearby songs in the catalog based on artist overlap, era, genre, and modeled earnings range.
            </p>
            <div class="comparison-list">
              <div class="comparison-row comparison-head">
                <span>Song</span>
                <span>Artist</span>
                <span>Estimated yearly midpoint</span>
              </div>
              <div class="comparison-row comparison-current">
                <div>
                  <a href={`${baseUrl}song/${song.slug}/`}><strong>{song.title}</strong></a>
                  <div class="comparison-reason">current page</div>
                </div>
                <span>{artist?.name ?? song.artist}</span>
                <strong>{formatRevenueMidpoint(song.normalizedRevenue?.artistSide?.midpoint)}</strong>
              </div>
              {comparisonSongs.map(({ song: comparisonSong, revenueScore, comparisonReason }) => (
                <div class="comparison-row">
                  <div>
                    <a href={`${baseUrl}song/${comparisonSong.slug}/`}>{comparisonSong.title}</a>
                    {comparisonReason && <div class="comparison-reason">{comparisonReason}</div>}
                  </div>
                  <span>{getArtist(comparisonSong.artist)?.name ?? comparisonSong.artist}</span>
                  <span>{formatRevenueMidpoint(revenueScore)}</span>
                </div>
              ))}
            </div>
          </section>
        )}

        {revenueBars.length > 1 && (
          <section aria-labelledby="revenue-visual-title">
            <h2 id="revenue-visual-title">Revenue Breakdown</h2>
            <div class="revenue-bars">
              {revenueBars.map((entry) => (
                <div class="revenue-bar-row">
                  <div class="revenue-bar-copy">
                    <strong>{entry.label}</strong>
                    <span>{entry.value}</span>
                  </div>
                  <div class="revenue-bar-track" aria-hidden="true">
                    <div class="revenue-bar-fill" style={`width: ${entry.width}%`}></div>
                  </div>
                  <div class="revenue-bar-scale">{entry.width}% of the lead revenue lane</div>
                </div>
              ))}
            </div>
            <p class="results-note">Bars reflect modeled annual midpoint ranges, not audited royalty statements.</p>
          </section>
        )}

        {hasPlatformSignals && (
          <section aria-labelledby="platform-signals-title" class="platform-signals-section">
            <h2 id="platform-signals-title">Platform Signals</h2>
            <p class="results-note">
              Public platform indicators, not complete streaming totals. Spotify exposes popularity, while YouTube exposes public video views.
            </p>
            <div class="platform-signal-grid">
              <article class="platform-signal-card">
                <div class="platform-signal-heading">
                  <span>Spotify</span>
                  {spotifyTrackUrl && <a href={spotifyTrackUrl} rel="noreferrer" target="_blank">Open</a>}
                </div>
                {platformMetrics?.spotifyPopularity !== undefined ? (
                  <>
                    <strong>{platformMetrics.spotifyPopularity}/100 popularity</strong>
                    <div class="platform-meter" aria-label={`Spotify popularity ${platformMetrics.spotifyPopularity} out of 100`}>
                      <span style={`width: ${platformMetrics.spotifyPopularity}%`}></span>
                    </div>
                  </>
                ) : (
                  <p>Popularity score not checked yet.</p>
                )}
              </article>

              <article class="platform-signal-card">
                <div class="platform-signal-heading">
                  <span>YouTube</span>
                  {youtubeVideoUrl && <a href={youtubeVideoUrl} rel="noreferrer" target="_blank">Open</a>}
                </div>
                {platformMetrics?.youtubeViews !== undefined ? (
                  <>
                    <strong>{numberFormatter.format(platformMetrics.youtubeViews)} public views</strong>
                    <p>{platformMetrics.youtubeSource ? youtubeSourceLabels[platformMetrics.youtubeSource] : "Tracked video"}</p>
                  </>
                ) : (
                  <p>{platformMetrics?.youtubeVideoId ? "Official video configured; view count will appear after the API refresh runs." : "No tracked video yet."}</p>
                )}
              </article>
            </div>
            <p class="results-note">
              {platformMetrics?.lastChecked
                ? `Last platform refresh: ${platformMetrics.lastChecked}.`
                : "Platform metrics are ready for refresh once API keys are configured."}
            </p>
          </section>
        )}

        {(song.player?.previewUrl || playerLinks.length > 0) && (
          <section aria-labelledby="player-title">
            <h2 id="player-title">Listen</h2>
            {song.player?.previewUrl ? (
              <>
                <p class="results-note">Official Apple Music preview.</p>
                <audio class="song-player" controls preload="none" src={song.player.previewUrl}>
                  Your browser does not support the audio element.
                </audio>
              </>
            ) : (
              <p class="results-note">Preview audio is not available for this song right now.</p>
            )}
            {playerLinks.length > 0 && (
              <div class="external-links">
                {playerLinks.map(([platform, url]) => (
                  <a class="external-link" href={url} rel="noreferrer" target="_blank">
                    {platform === "appleMusic"
                      ? "Apple Music"
                      : platform === "youtubeMusic"
                        ? "YouTube Music"
                        : platform === "amazonMusic"
                          ? "Amazon Music"
                          : "Spotify"}
                  </a>
                ))}
              </div>
            )}
          </section>
        )}

        <section aria-labelledby="questions-title">
          <h2 id="questions-title">More Questions About {song.title}</h2>
          <div class="intent-question-list">
            {intentQuestions.map((item) => (
              <article class="intent-question-card">
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))}
          </div>
        </section>

        {article && hasSourceContext && (
          <section aria-labelledby="sources-title">
            <h2 id="sources-title">Sources and References</h2>
            <p class="results-note">
              These points explain the public context used to frame this page. They support a
              directional model, not an audited royalty statement.
            </p>
            <p class="results-note">
              Published by How Much Music using the site methodology. If a source or estimate needs
              correction, use the <a href="/contact/">contact page</a>.
            </p>
            {evidenceItems.length > 0 && (
              <>
                <h3>Evidence used</h3>
                <ul class="meta-list">
                  {evidenceItems.map((point) => (
                    <li>{point}</li>
                  ))}
                </ul>
              </>
            )}
            {modelNotes.length > 0 && (
              <>
                <h3>Model notes</h3>
                <ul class="meta-list">
                  {modelNotes.map((point) => (
                    <li>{point}</li>
                  ))}
                </ul>
              </>
            )}
            {methodologyNotes.length > 0 && (
              <>
                <h3>Methodology limits</h3>
                <ul class="meta-list">
                  {methodologyNotes.map((point) => (
                    <li>{point}</li>
                  ))}
                </ul>
              </>
            )}
            {evidenceItems.length === 0 && methodologyNotes.length === 0 && modelNotes.length === 0 && (
              <ul class="meta-list">
                {[...detailedBreakdown, ...conciseWhy].slice(0, 8).map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            )}
            {allReferenceLinks.length > 0 && (
              <div class="reference-list">
                {allReferenceLinks.slice(0, 7).map((reference) => (
                  <article class="reference-item">
                    <h3><a href={reference.url} rel="noreferrer" target="_blank">{reference.label}</a></h3>
                    <p>{reference.note}</p>
                  </article>
                ))}
              </div>
            )}
          </section>
        )}

        <details class="details-card">
          <summary>Show ownership and assumptions</summary>
          <div class="details-card-body">
            <p>{ownershipNote}</p>

            <section aria-labelledby="breakdown-title">
              <h2 id="breakdown-title">Supporting Revenue Context</h2>
              <div class="compact-context-grid">
                {hasDetailedEarnings ? (
                  <>
                    {song.earnings?.gross_track_revenue && (
                      <div class="compact-context-card"><strong>Estimated gross track revenue</strong><span>{song.earnings.gross_track_revenue}</span></div>
                    )}
                    {song.earnings?.artist_or_estate_share && (
                      <div class="compact-context-card"><strong>Estimated artist-side cut</strong><span>{song.earnings.artist_or_estate_share}</span></div>
                    )}
                    {song.earnings?.label_master_share && (
                      <div class="compact-context-card"><strong>Estimated label master share</strong><span>{song.earnings.label_master_share}</span></div>
                    )}
                    {song.earnings?.publishing_share && (
                      <div class="compact-context-card"><strong>Estimated publishing share</strong><span>{song.earnings.publishing_share}</span></div>
                    )}
                    {song.earnings?.songwriter_share && (
                      <div class="compact-context-card"><strong>Estimated songwriter share</strong><span>{song.earnings.songwriter_share}</span></div>
                    )}
                    {song.ownership?.master_owner && (
                      <div class="compact-context-card"><strong>Masters</strong><span>{song.ownership.master_owner}</span></div>
                    )}
                    {song.ownership?.publishing_owner && (
                      <div class="compact-context-card"><strong>Publishing</strong><span>{song.ownership.publishing_owner}</span></div>
                    )}
                    {song.ownership?.catalog_sale_status && (
                      <div class="compact-context-card"><strong>Catalog sale status</strong><span>{song.ownership.catalog_sale_status}</span></div>
                    )}
                  </>
                ) : (
                  <>
                    {detailedBreakdown.slice(0, 4).map((point) => (
                      <div class="compact-context-card"><span>{point}</span></div>
                    ))}
                    <div class="compact-context-card"><strong>Lifetime estimate</strong><span>{article?.lifetimeEstimate ?? editorial.lifetime}</span></div>
                  </>
                )}
              </div>
              {song.earnings?.assumptions && <p class="results-note"><strong>Assumptions:</strong> {song.earnings.assumptions}</p>}
              {song.ownership?.notes && <p class="results-note"><strong>Notes:</strong> {song.ownership.notes}</p>}
            </section>

            <div class="methodology-card">
              <p class="methodology-badge">{methodology.confidenceLabel}</p>
              <p>{methodology.summary}</p>
              <ul class="meta-list">
                {methodology.bullets.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
              <p>
                <a href={`${baseUrl}insights/methodology/`}>Read the full site methodology.</a>
              </p>
            </div>
          </div>
        </details>

        {(moreFromAlbum.length > 0 || relatedAlbums.length > 0 || contextSongs.length > 0) && (
          <section aria-labelledby="more-context-title" class="song-context-section">
            <h2 id="more-context-title">More Context</h2>
            <div class="context-grid">
              {moreFromAlbum.length > 0 && (
                <div class="context-card">
                  <h3>More From This Album</h3>
                  <ul class="meta-list">
                    {moreFromAlbum.map((albumSong) => (
                      <li>
                        <a href={`${baseUrl}song/${albumSong.slug}/`}>{albumSong.title}</a>
                        <span class="meta-inline"> · {albumSong.estimated_revenue}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {relatedAlbums.length > 0 && (
                <div class="context-card">
                  <h3>Related Albums</h3>
                  <ul class="meta-list">
                    {relatedAlbums.map((relatedAlbum) => (
                      <li>
                        <a href={`${baseUrl}album/${relatedAlbum.slug}/`}>{relatedAlbum.title}</a>
                        <span class="meta-inline"> · {relatedAlbum.artistName}{relatedAlbum.year ? ` · ${relatedAlbum.year}` : ""}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {contextSongs.length > 0 && (
                <div class="context-card">
                  <h3>More From This Era</h3>
                  <ul class="meta-list">
                    {contextSongs.map((contextSong) => (
                      <li>
                        <a href={`${baseUrl}song/${contextSong.slug}/`}>{contextSong.title}</a>
                        <span class="meta-inline">
                          {" "}· {getArtist(contextSong.artist)?.name ?? contextSong.artist}
                          {contextSong.year ? ` · ${contextSong.year}` : ""}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </section>
        )}
      </div>

      <aside class="song-sidebar">
        <div class="song-summary-card">
          <p class="eyebrow">Earnings Snapshot</p>
          <h2>{leadRevenue}</h2>
          <ul class="stat-list">
            <li><strong>Artist:</strong> {artist ? <a href={`${baseUrl}artist/${artist.slug}/`}>{artist.name}</a> : song.artist}</li>
            {song.album && (
              <li>
                <strong>Album:</strong>{" "}
                {album ? <a href={`${baseUrl}album/${album.slug}/`}>{song.album}</a> : song.album}
              </li>
            )}
            {song.year && <li><strong>Released:</strong> {song.year}</li>}
            <li><strong>Confidence:</strong> {confidence.level}</li>
          </ul>
        </div>

        {relatedSongs.length > 0 && (
          <section aria-labelledby="related-title">
            <h2 id="related-title">Related Songs</h2>
            <ul class="meta-list">
              {relatedSongs.map((relatedSong) => (
                <li>
                  <a href={`${baseUrl}song/${relatedSong.slug}/`}>{relatedSong.title}</a>
                </li>
              ))}
            </ul>
          </section>
        )}

        {topEarningSongs.length > 0 && (
          <section aria-labelledby="top-songs-title">
            <h2 id="top-songs-title">Top Songs by Earnings</h2>
            <ul class="meta-list">
              {topEarningSongs.map(({ song: rankedSong, revenueScore }) => (
                <li>
                  <a href={`${baseUrl}song/${rankedSong.slug}/`}>{rankedSong.title}</a>
                  <span class="meta-inline">
                    {" "}· {getArtist(rankedSong.artist)?.name ?? rankedSong.artist}
                    {" "}· {formatRevenueMidpoint(revenueScore)}
                  </span>
                </li>
              ))}
            </ul>
          </section>
        )}
      </aside>
    </section>
  </article>
</BaseLayout>
