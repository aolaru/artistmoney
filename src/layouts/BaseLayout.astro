---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article";
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = "How Much Music tracks artist, song, and album pages with modeled music earnings data.",
  image,
  imageAlt = title,
  type = "website",
  jsonLd
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const socialImage = image ? new URL(image, Astro.url).toString() : null;
const jsonLdPayload = jsonLd
  ? JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : null;
const searchIndexUrl = `${baseUrl}search-index.json`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <meta property="og:site_name" content="How Much Music" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage && (
      <>
        <meta property="og:image" content={socialImage} />
        <meta property="og:image:alt" content={imageAlt} />
        <meta name="twitter:image" content={socialImage} />
      </>
    )}
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-8WMBDVPWEG"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-8WMBDVPWEG");
    </script>
    <title>{title}</title>
    {jsonLdPayload && (
      <script type="application/ld+json" set:html={jsonLdPayload} />
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href={baseUrl}>How Much Music</a>
        <form class="header-search" data-header-search action={`${baseUrl}search/`} method="get">
          <label class="sr-only" for="site-search">Search artists, songs, and albums</label>
          <input
            id="site-search"
            class="header-search-input"
            type="search"
            name="q"
            placeholder="Search artists, songs, albums"
            autocomplete="off"
            spellcheck="false"
            aria-autocomplete="list"
            aria-controls="header-search-results"
            aria-expanded="false"
          />
          <div class="header-search-panel" id="header-search-results" hidden>
            <div class="header-search-empty">Start typing to search the catalog.</div>
            <ul class="header-search-results" role="listbox"></ul>
            <a class="header-search-all-link" href={`${baseUrl}search/`}>Open full search</a>
          </div>
        </form>
        <nav aria-label="Primary navigation">
          <a href={baseUrl}>Home</a>
          <a href={`${baseUrl}artists/`}>Artists</a>
          <a href={`${baseUrl}albums/`}>Albums</a>
          <a href={`${baseUrl}songs/`}>Songs</a>
          <a href={`${baseUrl}genres/`}>Genres</a>
          <a href={`${baseUrl}decades/`}>Decades</a>
          <a href={`${baseUrl}updates/`}>Updates</a>
          <a href={`${baseUrl}insights/`}>Insights</a>
          <a href={`${baseUrl}credits/`}>Credits</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <p class="eyebrow">How Much Music</p>
          <p>
            Music earnings, catalog value, and artist-side estimates presented as editorial
            research.
          </p>
        </div>

        <div>
          <p class="footer-heading">Browse</p>
          <nav class="footer-nav" aria-label="Footer navigation">
            <a href={baseUrl}>Home</a>
            <a href={`${baseUrl}artists/`}>Artists</a>
            <a href={`${baseUrl}albums/`}>Albums</a>
            <a href={`${baseUrl}songs/`}>Songs</a>
            <a href={`${baseUrl}genres/`}>Genres</a>
            <a href={`${baseUrl}decades/`}>Decades</a>
            <a href={`${baseUrl}updates/`}>Updates</a>
            <a href={`${baseUrl}insights/`}>Insights</a>
            <a href={`${baseUrl}credits/`}>Credits</a>
          </nav>
        </div>

        <div>
          <p class="footer-heading">Rankings</p>
          <nav class="footer-nav" aria-label="Footer rankings navigation">
            <a href={`${baseUrl}top-artists/`}>Top Artists</a>
            <a href={`${baseUrl}top-songs/`}>Top Songs</a>
            <a href={`${baseUrl}catalogs/`}>Top Catalogs</a>
            <a href={`${baseUrl}insights/methodology/`}>Methodology</a>
          </nav>
        </div>

        <div>
          <p class="footer-heading">Notes</p>
          <p class="footer-note">
            Earnings are estimates, not public royalty statements. Image licenses and rights notes
            are listed on the credits page.
          </p>
          <p class="footer-note">© 2026 How Much Music</p>
        </div>
      </div>
    </footer>
    <script is:inline define:vars={{ searchIndexUrl }}>
      (() => {
        let searchItemsPromise;

        const normalize = (value) => value.toLowerCase().trim();

        const scoreItem = (item, query) => {
          const title = item.titleLower;
          const subtitle = item.subtitleLower ?? "";
          const searchText = item.searchText;

          let score = 0;
          if (title === query) score += 300;
          if (title.startsWith(query)) score += 180;
          if (title.includes(query)) score += 120;
          if (subtitle.startsWith(query)) score += 70;
          if (subtitle.includes(query)) score += 40;
          if (searchText.includes(query)) score += 20;
          return score;
        };

        const fetchSearchItems = async () => {
          if (!searchItemsPromise) {
            searchItemsPromise = fetch(searchIndexUrl)
              .then((response) => {
                if (!response.ok) {
                  throw new Error(`Search index request failed: ${response.status}`);
                }
                return response.json();
              })
              .then((items) => items.map((item) => ({
                ...item,
                titleLower: item.title.toLowerCase(),
                subtitleLower: (item.subtitle ?? "").toLowerCase(),
                searchText: item.searchText.toLowerCase()
              })));
          }

          return searchItemsPromise;
        };

        const initHeaderSearch = () => {
          document.querySelectorAll("[data-header-search]").forEach((root) => {
            if (root.dataset.bound === "true") return;
            root.dataset.bound = "true";

            const input = root.querySelector(".header-search-input");
            const panel = root.querySelector(".header-search-panel");
            const list = root.querySelector(".header-search-results");
            const empty = root.querySelector(".header-search-empty");
            const allLink = root.querySelector(".header-search-all-link");

            if (!input || !panel || !list || !empty || !allLink) return;

            let suggestions = [];
            let activeIndex = -1;

            const closePanel = () => {
              panel.hidden = true;
              input.setAttribute("aria-expanded", "false");
              activeIndex = -1;
            };

            const openPanel = () => {
              panel.hidden = false;
              input.setAttribute("aria-expanded", "true");
            };

            const render = () => {
              list.innerHTML = "";
              const query = input.value.trim();
              allLink.href = query ? `${baseUrl}search/?q=${encodeURIComponent(query)}` : `${baseUrl}search/`;

              if (suggestions.length === 0) {
                empty.hidden = false;
                empty.textContent = query
                  ? "No matching artists, songs, or albums."
                  : "Start typing to search the catalog.";
                openPanel();
                return;
              }

              empty.hidden = true;

              suggestions.forEach((item, index) => {
                const li = document.createElement("li");
                li.setAttribute("role", "option");
                li.className = "header-search-item";
                if (index === activeIndex) li.classList.add("is-active");

                const link = document.createElement("a");
                link.href = item.url;
                link.className = "header-search-link";
                link.innerHTML = `
                  <span class="header-search-type">${item.type}</span>
                  <strong>${item.title}</strong>
                  <span class="header-search-meta">${item.subtitle ?? ""}</span>
                `;

                li.appendChild(link);
                list.appendChild(li);
              });

              openPanel();
            };

            const updateActive = (nextIndex) => {
              if (suggestions.length === 0) return;
              activeIndex = (nextIndex + suggestions.length) % suggestions.length;
              render();
            };

            const updateSuggestions = async () => {
              const query = normalize(input.value);
              if (!query) {
                suggestions = [];
                render();
                return;
              }

              try {
                const items = await fetchSearchItems();
                suggestions = items
                  .map((item) => ({ item, score: scoreItem(item, query) }))
                  .filter((entry) => entry.score > 0)
                  .sort((left, right) => right.score - left.score || left.item.title.localeCompare(right.item.title))
                  .slice(0, 8)
                  .map((entry) => entry.item);
                activeIndex = suggestions.length > 0 ? 0 : -1;
                render();
              } catch (_error) {
                suggestions = [];
                empty.hidden = false;
                empty.textContent = "Search is unavailable right now.";
                openPanel();
              }
            };

            input.addEventListener("focus", () => {
              if (!panel.hidden || input.value.trim()) {
                render();
              } else {
                openPanel();
              }
              fetchSearchItems().catch(() => {});
            });

            input.addEventListener("input", () => {
              updateSuggestions();
            });

            input.addEventListener("keydown", (event) => {
              if (event.key === "ArrowDown") {
                event.preventDefault();
                updateActive(activeIndex + 1);
                return;
              }

              if (event.key === "ArrowUp") {
                event.preventDefault();
                updateActive(activeIndex - 1);
                return;
              }

              if (event.key === "Escape") {
                closePanel();
                return;
              }

              if (event.key === "Enter" && activeIndex >= 0 && suggestions[activeIndex]) {
                event.preventDefault();
                window.location.href = suggestions[activeIndex].url;
                return;
              }
            });

            document.addEventListener("click", (event) => {
              if (!root.contains(event.target)) {
                closePanel();
              }
            });
          });
        };

        initHeaderSearch();
        document.addEventListener("astro:page-load", initHeaderSearch);
      })();
    </script>
  </body>
</html>
