---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article";
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = "How Much Music tracks artist, song, and album pages with modeled music earnings data.",
  image,
  imageAlt = title,
  type = "website",
  jsonLd
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const socialImage = image ? new URL(image, Astro.url).toString() : null;
const jsonLdPayload = jsonLd
  ? JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <meta property="og:site_name" content="How Much Music" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage && (
      <>
        <meta property="og:image" content={socialImage} />
        <meta property="og:image:alt" content={imageAlt} />
        <meta name="twitter:image" content={socialImage} />
      </>
    )}
    <title>{title}</title>
    {jsonLdPayload && (
      <script type="application/ld+json" set:html={jsonLdPayload} />
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href={baseUrl}>How Much Music</a>
        <nav aria-label="Primary navigation">
          <a href={baseUrl}>Home</a>
          <a href={`${baseUrl}artists/`}>Artists</a>
          <a href={`${baseUrl}albums/`}>Albums</a>
          <a href={`${baseUrl}songs/`}>Songs</a>
          <a href={`${baseUrl}genres/`}>Genres</a>
          <a href={`${baseUrl}decades/`}>Decades</a>
          <a href={`${baseUrl}insights/`}>Insights</a>
          <a href={`${baseUrl}credits/`}>Credits</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <p class="eyebrow">How Much Music</p>
          <p>
            Music earnings, catalog value, and artist-side estimates presented as editorial
            research.
          </p>
        </div>

        <div>
          <p class="footer-heading">Browse</p>
          <nav class="footer-nav" aria-label="Footer navigation">
            <a href={baseUrl}>Home</a>
            <a href={`${baseUrl}artists/`}>Artists</a>
            <a href={`${baseUrl}albums/`}>Albums</a>
            <a href={`${baseUrl}songs/`}>Songs</a>
            <a href={`${baseUrl}genres/`}>Genres</a>
            <a href={`${baseUrl}decades/`}>Decades</a>
            <a href={`${baseUrl}insights/`}>Insights</a>
            <a href={`${baseUrl}credits/`}>Credits</a>
          </nav>
        </div>

        <div>
          <p class="footer-heading">Rankings</p>
          <nav class="footer-nav" aria-label="Footer rankings navigation">
            <a href={`${baseUrl}top-artists/`}>Top Artists</a>
            <a href={`${baseUrl}top-songs/`}>Top Songs</a>
            <a href={`${baseUrl}catalogs/`}>Top Catalogs</a>
            <a href={`${baseUrl}insights/methodology/`}>Methodology</a>
          </nav>
        </div>

        <div>
          <p class="footer-heading">Notes</p>
          <p class="footer-note">
            Earnings are estimates, not public royalty statements. Image licenses and rights notes
            are listed on the credits page.
          </p>
          <p class="footer-note">© 2026 How Much Music</p>
        </div>
      </div>
    </footer>
  </body>
</html>
